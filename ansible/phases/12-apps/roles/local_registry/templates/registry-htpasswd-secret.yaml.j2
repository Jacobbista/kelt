{#
  htpasswd auth for registry:2. The bcrypt line is generated here (passlib on the
  control host) and the Secret is only ever CREATED when absent (see tasks), so the
  random bcrypt salt does not churn the Secret on re-runs. Delete the Secret to
  rotate the password. registry:2 accepts the $2b$ bcrypt format passlib emits.
#}
apiVersion: v1
kind: Secret
metadata:
  name: {{ registry_app_name }}-auth
  namespace: {{ registry_namespace }}
  labels:
    app: {{ registry_app_name }}
type: Opaque
stringData:
  htpasswd: "{{ apps_registry_username }}:{{ apps_registry_password | password_hash('bcrypt') }}"
