{#
  Front-door nginx config. One server block per public subdomain, routed by Host
  to the matching in-cluster Service. Cloudflare terminates TLS and forwards a
  single wildcard *.{{ external_base_domain }} to this NodePort over HTTP, so all
  surfaces share one tunnel route and one Access app. See
  docs/security/external-access.md.

  Upstreams are resolved at request time via the cluster DNS resolver and a
  variable proxy_pass, so a disabled-or-not-yet-deployed service yields a 502
  rather than crashing nginx at startup. Northbound server blocks are emitted
  only when their feature flag is on.
#}
apiVersion: v1
kind: ConfigMap
metadata:
  name: frontdoor-nginx
  namespace: {{ frontdoor_namespace }}
data:
  nginx.conf: |
    worker_processes auto;
    events { worker_connections 1024; }
    http {
      access_log /dev/stdout;
      error_log  /dev/stderr warn;

      # Cluster DNS for runtime upstream resolution (variable proxy_pass below).
      resolver {{ cluster_dns_ip }} valid=10s ipv6=off;

      # WebSocket upgrade (Vite HMR on the dev surface, live log streams).
      map $http_upgrade $connection_upgrade { default upgrade; '' close; }

      proxy_http_version 1.1;
      proxy_set_header Host              $host;
      proxy_set_header X-Real-IP         $remote_addr;
      proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
      proxy_set_header X-Forwarded-Proto {{ external_scheme }};
      proxy_set_header X-Forwarded-Host  $host;
      proxy_set_header Upgrade           $http_upgrade;
      proxy_set_header Connection        $connection_upgrade;

      # OIDC cookies/tokens are large; keep generous header buffers.
      proxy_buffer_size          16k;
      proxy_buffers           4  16k;
      large_client_header_buffers 4 16k;
      client_max_body_size       25m;

      # The front-door catalogue lives at <prefix>.<base> (e.g. kelt.<base>). An
      # operator who does not know what is deployed — or picked the wrong route —
      # comes here to discover and reach each surface. Pre-auth: it only lists names +
      # links; each service enforces its own Keycloak gate. The Cloudflare wildcard
      # tunnel (*.<base>) forwards every KELT host here; the operator's own subdomains
      # keep their explicit DNS records and never reach this front-door. See
      # docs/security/external-access.md.
      server {
        listen 80;
        server_name {{ catalogue_subdomain }}.{{ external_base_domain }};
        root /usr/share/nginx/html;
        # Exact match wins, so the co-brand JSON is served as itself; everything
        # else falls back to the welcome page.
        location = /brand.json { default_type application/json; }
{% if apps_enabled | default(false) | bool %}
        # Live list of deployed edge apps (names + URLs) for the welcome page,
        # via the dashboard backend's unauthenticated endpoint. Same data the
        # static catalogue shows; the page fetches it client-side.
        location = /apps.json {
          set $up http://dashboard-frontend.{{ frontdoor_dashboard_namespace }}.svc.cluster.local:{{ frontdoor_dashboard_port }}/api/v1/apps/public;
          proxy_pass $up;
        }
{% endif %}
        # The catalogue is a single static landing: the root serves it; any other
        # path is stray (the real app routes live on the dashboard host), so bounce
        # it to the clean root rather than rendering the catalogue under a junk URL.
        location = / { default_type text/html; try_files /index.html =404; }
        location / { return 302 /; }
      }

      # Everything that is NOT a real surface — an unknown Host, direct-IP access, or
      # (via the per-app fallback below) a mistyped/undeployed app subdomain — gets a
      # branded 404 with a button back to the catalogue. A wrong address never
      # silently renders the full directory; it points the way back instead.
      server {
        listen 80 default_server;
        root /usr/share/nginx/html;
        error_page 404 /notfound.html;
        location = /notfound.html { internal; }
        location / { return 404; }
      }

      # kelt-dashboard.<base> -> dashboard frontend (serves /, and reverse-proxies
      # /auth /api /docs internally, so this one route covers Keycloak too).
      server {
        listen 80;
        server_name {{ dashboard_subdomain }}.{{ external_base_domain }};
        location / {
          set $up http://dashboard-frontend.{{ frontdoor_dashboard_namespace }}.svc.cluster.local:{{ frontdoor_dashboard_port }};
          proxy_pass $up;
        }
      }
{% if camara_enabled | default(false) | bool %}

      # api.<base> -> CAMARA Location API gateway (M2M; Access Bypass at the edge).
      server {
        listen 80;
        server_name {{ camara_subdomain }}.{{ external_base_domain }};
        location / {
          set $up http://camara-gateway.{{ frontdoor_camara_namespace }}.svc.cluster.local:{{ frontdoor_camara_port }};
          proxy_pass $up;
        }
      }
{% endif %}
{% if positioning_demo_enabled | default(false) | bool %}

      # demo.<base> -> positioning demo SPA.
      server {
        listen 80;
        server_name {{ positioning_demo_subdomain }}.{{ external_base_domain }};
        location / {
          set $up http://positioning-demo.{{ frontdoor_demo_namespace }}.svc.cluster.local:{{ frontdoor_demo_port }};
          proxy_pass $up;
        }
      }
{% endif %}
{% if placement_editor_enabled | default(false) | bool %}

      # placement.<base> -> oauth2-proxy gate -> placement-editor (Keycloak login).
      server {
        listen 80;
        server_name {{ placement_editor_subdomain }}.{{ external_base_domain }};
        location / {
          set $up http://oauth2-proxy-placement.{{ frontdoor_placement_namespace }}.svc.cluster.local:{{ frontdoor_placement_port }};
          proxy_pass $up;
        }
      }
{% endif %}
{% if frontdoor_dev_enabled | default(false) | bool %}

      # dev.<base> -> Vite dev server on the ansible VM (off-cluster upstream).
      # Literal IP, so no DNS resolution; HMR rides the WebSocket upgrade above.
      server {
        listen 80;
        server_name {{ dashboard_dev_subdomain }}.{{ external_base_domain }};
        location / {
          proxy_pass http://{{ frontdoor_dev_upstream }};
        }
      }
{% endif %}
{% if apps_enabled | default(false) | bool %}

      # <prefix>-<app>.<base> -> operator-deployed edge app (phase 12). Dynamic: the
      # named server blocks above win by exact match, so any OTHER <prefix>-<name>
      # host is treated as an app and proxied to the same-named Service (the prefix is
      # stripped: kelt-face -> Service "face") in the apps namespace, resolved at
      # request time. A new app is reachable the moment its Service exists, with no
      # template edit / front-door re-run. A mistyped name, or an app that does not
      # exist / is down, lands on the branded 404 below (button back to the
      # catalogue). See docs/architecture/edge-apps.md.
      server {
        listen 80;
        server_name ~^{{ kelt_prefix }}-(?<app>[^.]+)\.{{ external_base_domain | regex_escape }}$;
        root /usr/share/nginx/html;
        # Branded 404 ONLY when KELT itself cannot reach the app: the Service name
        # does not resolve (no such app) or the upstream refuses / times out — both
        # surface as nginx-generated 502/504. proxy_intercept_errors stays OFF (the
        # default), so an app that IS reachable and returns its OWN 5xx (e.g. a 503
        # maintenance page, or its own 502) passes through untouched rather than
        # being masked by our 404. See docs/architecture/edge-apps.md.
        location = /notfound.html { internal; }
        location / {
          set $up http://$app.{{ apps_namespace }}.svc.cluster.local;
          proxy_pass $up;
          error_page 502 504 =404 /notfound.html;
        }
      }
{% endif %}
    }
  # Public, branded welcome page served on the default (unknown-host) server.
  # Built from the same subdomain map + feature flags that drive the routing
  # above, so it never drifts. Brand (name, tagline, accent) is overridable via
  # the frontdoor_brand_* vars. Each link lands on a service that enforces its
  # own Keycloak gate; this page only lists names + links (pre-auth).
  index.html: |
    <!doctype html>
    <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>{{ frontdoor_brand_title }} · Services</title>
      <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cg fill='none' stroke-linecap='round'%3E%3Cpath d='M21 58 C15 50 27 43 21 35 C15 28 25 21 21 14' stroke='%2314b8a6' stroke-width='4'/%3E%3Cpath d='M32 58 C26 49 38 41 32 33 C26 25 38 17 32 8' stroke='%230d9488' stroke-width='4'/%3E%3Cpath d='M43 58 C49 50 37 43 43 35 C49 28 39 22 43 16' stroke='%2314b8a6' stroke-width='4'/%3E%3C/g%3E%3Cg fill='%23f59e0b'%3E%3Ccircle cx='32' cy='8' r='2.8'/%3E%3Ccircle cx='21' cy='14' r='2.6'/%3E%3Ccircle cx='43' cy='16' r='2.6'/%3E%3C/g%3E%3C/svg%3E" />
      <style>
        :root { color-scheme: dark; --accent: {{ frontdoor_brand_accent }}; }
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
               background: radial-gradient(1200px 600px at 50% -10%, #0d2b2a 0%, #0b1120 55%); color: #e2e8f0;
               font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; }
        main { width: 100%; max-width: 680px; padding: 2.5rem 1.25rem; }
        header { text-align: center; margin-bottom: 2rem; }
        .mark { width: 46px; height: 46px; display: block; }
        h1 { font-size: 1.7rem; letter-spacing: .04em; margin: 0; }
        h1 .acc { color: var(--accent); }
        .brandrow { display: flex; align-items: center; justify-content: center; gap: 1.1rem; flex-wrap: wrap; }
        .kelt { display: flex; align-items: center; gap: .55rem; }
        #cobrand { display: flex; align-items: center; gap: .7rem; }
        .divider { width: 1px; height: 44px; background: #334155; }
        p.sub { margin: .4rem 0 0; color: #94a3b8; font-size: .95rem; }
        a.card { display: flex; align-items: center; gap: .9rem; text-decoration: none;
                 border: 1px solid #1e293b; background: rgba(15,23,42,.7); border-radius: .7rem;
                 padding: .95rem 1.1rem; margin-bottom: .7rem; transition: transform .12s, background .15s, border-color .15s; }
        a.card:hover { background: #131c30; border-color: var(--accent); transform: translateY(-1px); }
        .dot { width: .55rem; height: .55rem; border-radius: 50%; background: var(--accent); flex: none; box-shadow: 0 0 10px var(--accent); }
        .body { display: flex; flex-direction: column; }
        .name { color: #f1f5f9; font-weight: 600; }
        .host { color: #5eead4; font-family: ui-monospace, monospace; font-size: .78rem; }
        .desc { color: #94a3b8; font-size: .8rem; margin-left: auto; text-align: right; }
        footer { margin-top: 1.5rem; text-align: center; color: #64748b; font-size: .75rem; }
        footer .lock { color: var(--accent); }

        /* Splash intro: KELT mark scales in, name + motto rise, then the co-brand
           ("operated by" + org) fades in after, then the service cards stagger in. */
        @keyframes riseIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
        @keyframes markIn { from { opacity: 0; transform: scale(.78) rotate(-6deg); } to { opacity: 1; transform: none; } }
        .kelt .mark { animation: markIn .7s cubic-bezier(.2,.7,.2,1) both; }
        .kelt h1 { animation: riseIn .6s ease both .15s; }
        p.sub { animation: riseIn .6s ease both .32s; }
        #cobrand { opacity: 0; transform: translateX(-8px); transition: opacity .8s ease, transform .8s ease; }
        #cobrand.show { opacity: 1; transform: none; }
        a.card { opacity: 0; animation: riseIn .5s ease forwards; }
        a.card:nth-of-type(1) { animation-delay: .5s; }
        a.card:nth-of-type(2) { animation-delay: .58s; }
        a.card:nth-of-type(3) { animation-delay: .66s; }
        a.card:nth-of-type(4) { animation-delay: .74s; }
        a.card:nth-of-type(n+5) { animation-delay: .82s; }
        footer { animation: riseIn .6s ease both .9s; }
        @media (prefers-reduced-motion: reduce) {
          .kelt .mark, .kelt h1, p.sub, a.card, footer { animation: none; opacity: 1; }
          #cobrand { transition: none; }
        }
      </style>
    </head>
    <body>
      <main>
        <header>
          <!-- KELT and the org co-brand sit side by side, split by a thin rule.
               KELT stays primary; the org (set from the dashboard, /brand.json)
               appears beside it so the page reads as "<Org>'s private 5G testbed".
               #cobrand is filled by the script below; empty by default. -->
          <div class="brandrow">
            <div class="kelt">
              <svg class="mark" viewBox="0 0 64 64" aria-hidden="true">
                <g fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 58 Q32 63 48 58" stroke="#0f766e" stroke-width="3"/>
                  <path d="M21 58 C15 50 27 43 21 35 C15 28 25 21 21 14" stroke="#14b8a6" stroke-width="4"/>
                  <path d="M32 58 C26 49 38 41 32 33 C26 25 38 17 32 8" stroke="#0d9488" stroke-width="4"/>
                  <path d="M43 58 C49 50 37 43 43 35 C49 28 39 22 43 16" stroke="#14b8a6" stroke-width="4"/>
                </g>
                <g fill="#f59e0b">
                  <circle cx="21" cy="14" r="2.6"/><circle cx="32" cy="8" r="2.8"/>
                  <circle cx="43" cy="16" r="2.6"/><circle cx="33.5" cy="33" r="2.2"/>
                </g>
              </svg>
              <h1>{{ frontdoor_brand_title | upper }}</h1>
            </div>
            <span id="cobrand"></span>
          </div>
          <p class="sub" id="tagline">{{ frontdoor_brand_tagline }}</p>
        </header>
        <a class="card" href="{{ external_scheme }}://{{ dashboard_subdomain }}.{{ external_base_domain }}/">
          <span class="dot"></span><span class="body"><span class="name">Dashboard</span><span class="host">{{ dashboard_subdomain }}.{{ external_base_domain }}</span></span>
          <span class="desc">control room</span>
        </a>
{% if positioning_demo_enabled | default(false) | bool %}
        <a class="card" href="{{ external_scheme }}://{{ positioning_demo_subdomain }}.{{ external_base_domain }}/">
          <span class="dot"></span><span class="body"><span class="name">Positioning Demo</span><span class="host">{{ positioning_demo_subdomain }}.{{ external_base_domain }}</span></span>
          <span class="desc">live 3D map</span>
        </a>
{% endif %}
{% if placement_editor_enabled | default(false) | bool %}
        <a class="card" href="{{ external_scheme }}://{{ placement_editor_subdomain }}.{{ external_base_domain }}/">
          <span class="dot"></span><span class="body"><span class="name">Placement Editor</span><span class="host">{{ placement_editor_subdomain }}.{{ external_base_domain }}</span></span>
          <span class="desc">room geometry</span>
        </a>
{% endif %}
{% if camara_enabled | default(false) | bool %}
        <a class="card" href="{{ external_scheme }}://{{ camara_subdomain }}.{{ external_base_domain }}/docs">
          <span class="dot"></span><span class="body"><span class="name">CAMARA Location API</span><span class="host">{{ camara_subdomain }}.{{ external_base_domain }}</span></span>
          <span class="desc">OpenAPI docs</span>
        </a>
{% endif %}
{% if apps_enabled | default(false) | bool %}
        <div id="edge-apps-section" style="display:none">
          <p style="margin:1.5rem 0 .5rem;color:#64748b;font-size:.62rem;text-transform:uppercase;letter-spacing:.16em">Edge apps</p>
          <div id="edge-apps"></div>
        </div>
{% endif %}
        <footer><span class="lock">&#128274;</span> Each service prompts for login on entry.</footer>
      </main>
      <script>
        // Co-brand from the dashboard-managed /brand.json (org name + logo +
        // optional accent). Absent/empty -> KELT only. Kept tiny and dependency-free.
        fetch('/brand.json', { cache: 'no-store' }).then(function (r) { return r.ok ? r.json() : null; }).then(function (b) {
          if (!b) return;
          if (b.accent) document.documentElement.style.setProperty('--accent', b.accent);
          if (b.tagline) document.getElementById('tagline').textContent = b.tagline;
          if (!b.org_name && !b.org_logo) return;
          var logo = '';
          if (b.org_logo) {
            logo = '<img src="' + b.org_logo + '" alt="" style="height:40px;max-width:200px;object-fit:contain;display:block" />';
            // Optional backdrop so the logo stays legible on the dark page.
            var plate = {
              light: 'background:#ffffff;padding:7px 11px;border-radius:9px',
              dark: 'background:#0b1120;border:1px solid #1e293b;padding:7px 11px;border-radius:9px',
              glass: 'background:rgba(148,163,184,.10);border:1px solid rgba(148,163,184,.22);border-radius:10px;padding:7px 11px;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);box-shadow:0 2px 14px rgba(0,0,0,.28)'
            }[b.logo_bg];
            if (plate) logo = '<span style="display:inline-flex;' + plate + '">' + logo + '</span>';
          }
          var name = b.org_name ? '<span style="color:#f1f5f9;font-size:1.15rem;font-weight:600">' + b.org_name + '</span>' : '';
          // Side by side with KELT, split by a thin vertical rule; "operated by"
          // sits as a small label above the org so the ownership reads clearly.
          var el = document.getElementById('cobrand');
          el.innerHTML = '<span class="divider"></span>'
            + '<div style="display:flex;flex-direction:column;align-items:center;gap:.4rem">'
            + '<span style="color:#64748b;font-size:.6rem;text-transform:uppercase;letter-spacing:.16em">operated by</span>'
            + '<div style="display:flex;align-items:center;gap:.6rem">' + logo + name + '</div></div>';
          // Reveal after the KELT splash has settled, so "operated by <org>"
          // transitions in rather than appearing at once.
          setTimeout(function () { el.classList.add('show'); }, 750);
        }).catch(function () {});
      </script>
{% if apps_enabled | default(false) | bool %}
      <script>
        // Deployed edge apps (live, from the dashboard's unauthenticated list).
        // Rendered as their own group so they never blur into the core services.
        // Hidden entirely when none are deployed.
        fetch('/apps.json', { cache: 'no-store' }).then(function (r) { return r.ok ? r.json() : { apps: [] }; }).then(function (d) {
          var apps = (d && d.apps) || [];
          if (!apps.length) return;
          var host = function (u) { return u.replace(/^https?:\/\//, ''); };
          document.getElementById('edge-apps').innerHTML = apps.map(function (a) {
            return '<a class="card" href="' + a.url + '">'
              + '<span class="dot"></span>'
              + '<span class="body"><span class="name">' + a.name + '</span>'
              + '<span class="host">' + host(a.url) + '</span></span>'
              + '<span class="desc">' + (a.ready ? 'edge app' : 'starting…') + '</span></a>';
          }).join('');
          document.getElementById('edge-apps-section').style.display = 'block';
        }).catch(function () {});
      </script>
{% endif %}
    </body>
    </html>
  # Branded 404 served for any address that is not a real surface (unknown Host,
  # direct IP, or a mistyped / undeployed app subdomain). KELT-only and
  # self-contained (no fetches), with a single button back to the catalogue at the
  # base. See docs/security/external-access.md.
  notfound.html: |
    <!doctype html>
    <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <title>{{ frontdoor_brand_title }} · Not found</title>
      <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cg fill='none' stroke-linecap='round'%3E%3Cpath d='M21 58 C15 50 27 43 21 35 C15 28 25 21 21 14' stroke='%2314b8a6' stroke-width='4'/%3E%3Cpath d='M32 58 C26 49 38 41 32 33 C26 25 38 17 32 8' stroke='%230d9488' stroke-width='4'/%3E%3Cpath d='M43 58 C49 50 37 43 43 35 C49 28 39 22 43 16' stroke='%2314b8a6' stroke-width='4'/%3E%3C/g%3E%3Cg fill='%23f59e0b'%3E%3Ccircle cx='32' cy='8' r='2.8'/%3E%3Ccircle cx='21' cy='14' r='2.6'/%3E%3Ccircle cx='43' cy='16' r='2.6'/%3E%3C/g%3E%3C/svg%3E" />
      <style>
        :root { color-scheme: dark; --accent: {{ frontdoor_brand_accent }}; }
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
               background: radial-gradient(1200px 600px at 50% -10%, #0d2b2a 0%, #0b1120 55%); color: #e2e8f0;
               font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; text-align: center; }
        main { max-width: 520px; padding: 2.5rem 1.25rem; }
        .mark { width: 54px; height: 54px; margin: 0 auto 1.2rem; display: block; }
        h1 { font-size: 1.5rem; letter-spacing: .03em; margin: 0 0 .6rem; }
        h1 .acc { color: var(--accent); }
        p { color: #94a3b8; margin: .3rem 0 1.6rem; font-size: .95rem; line-height: 1.5; }
        a.btn { display: inline-flex; align-items: center; gap: .5rem; text-decoration: none;
                border: 1px solid var(--accent); color: #f1f5f9; background: rgba(20,184,166,.08);
                border-radius: .6rem; padding: .7rem 1.2rem; font-weight: 600; transition: background .15s; }
        a.btn:hover { background: rgba(20,184,166,.18); }
        .host { color: #5eead4; font-family: ui-monospace, monospace; font-size: .78rem; margin-top: 1.4rem; }
      </style>
    </head>
    <body>
      <main>
        <svg class="mark" viewBox="0 0 64 64" aria-hidden="true">
          <g fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 58 Q32 63 48 58" stroke="#0f766e" stroke-width="3"/>
            <path d="M21 58 C15 50 27 43 21 35 C15 28 25 21 21 14" stroke="#14b8a6" stroke-width="4"/>
            <path d="M32 58 C26 49 38 41 32 33 C26 25 38 17 32 8" stroke="#0d9488" stroke-width="4"/>
            <path d="M43 58 C49 50 37 43 43 35 C49 28 39 22 43 16" stroke="#14b8a6" stroke-width="4"/>
          </g>
          <g fill="#f59e0b">
            <circle cx="21" cy="14" r="2.6"/><circle cx="32" cy="8" r="2.8"/>
            <circle cx="43" cy="16" r="2.6"/><circle cx="33.5" cy="33" r="2.2"/>
          </g>
        </svg>
        <h1>Not a <span class="acc">{{ frontdoor_brand_title }}</span> service</h1>
        <p>This address does not match any deployed surface, or the service is not
           reachable right now. Head back to the front door to see what is available.</p>
        <a class="btn" href="{{ external_scheme }}://{{ catalogue_subdomain }}.{{ external_base_domain }}/">&#8592; {{ frontdoor_brand_title }} services</a>
        <p class="host">{{ catalogue_subdomain }}.{{ external_base_domain }}</p>
      </main>
    </body>
    </html>
