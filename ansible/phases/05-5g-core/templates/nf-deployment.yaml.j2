apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ nf.name }}
  namespace: {{ namespace_5g }}
{% set has_static_secondary_ips = (nf.networks | default([]) | selectattr('ips', 'defined') | list | length) > 0 %}
spec:
  replicas: {{ nf.replicas | default(1) }}
{% if has_static_secondary_ips %}
  # Static Multus IPs cannot be safely rolled with overlapping old/new pods.
  strategy:
    rollingUpdate: null
    type: Recreate
{% endif %}
  selector:
    matchLabels:
      app: {{ nf.name }}
  template:
    metadata:
      labels:
        app: {{ nf.name }}
      annotations:
        checksum/config: "{{ lookup('template', playbook_dir + '/configs/' ~ (nf.name | replace('-', '_')) ~ '.yaml') | hash('sha256') }}"
{% if nf.setup_script is defined %}
        checksum/setup: "{{ lookup('file', playbook_dir + '/scripts/' ~ nf.setup_script) | hash('sha256') }}"
{% endif %}
{% if nf.networks is defined %}
        k8s.v1.cni.cncf.io/networks: |
          {{ nf.networks | to_json }}
{% endif %}
    spec:
      terminationGracePeriodSeconds: 15
      nodeSelector:
        kubernetes.io/hostname: {{ nf.node | default('worker') }}
      initContainers:
{% if nf.enable_rp_filter_fix | default(false) %}
      - name: sysctl-init
        image: busybox
        command: ["/bin/sh", "-c"]
        args:
          - |
            sysctl -w net.ipv4.conf.all.rp_filter=0
            sysctl -w net.ipv4.conf.default.rp_filter=0
            sysctl -w net.ipv4.ip_forward=1
            echo "sysctl ready for {{ nf.name }}"
        securityContext:
          privileged: true
{% endif %}
      - name: wait-deps
        image: busybox
        command: ["/bin/sh", "-c"]
        args:
          - |
{% if nf.db_required | default(true) %}
            until nc -z mongodb 27017; do echo "waiting mongodb..."; sleep 2; done
{% endif %}
{% if nf.name != 'nrf' %}
            until nc -z nrf 7777; do echo "waiting nrf..."; sleep 2; done
{% endif %}
{% for iface in nf.wait_interfaces | default([]) %}
            until ip addr show {{ iface }} 2>/dev/null | grep -q "inet"; do echo "waiting {{ iface }} IP..."; sleep 1; done
{% endfor %}
            echo "deps ready"
{% if nf.setup_script is defined %}
      # Testbed-specific network setup (TUN interfaces, policy routing, iptables).
      # Uses netshoot image for ip/iptables/sysctl tools (NF images are minimal).
      - name: network-setup
        image: {{ network_setup_image }}
        command: ["/bin/sh", "/scripts/{{ nf.setup_script }}"]
        securityContext:
          privileged: true
        volumeMounts:
        - name: nf-scripts
          mountPath: /scripts
{% endif %}
      containers:
      - name: {{ nf.name }}
        image: {{ nf.image }}
        imagePullPolicy: IfNotPresent
{% if nf.lifecycle_post_start is defined %}
        lifecycle:
          postStart:
            exec:
              command: ["/bin/sh", "-c", "{{ nf.lifecycle_post_start }}"]
{% endif %}
        args: ["-c", "/etc/open5gs/{{ nf.name | replace('-', '_') }}.yaml"]
        ports:
{% for port in nf.ports %}
        - containerPort: {{ port.port }}
          name: {{ port.name }}
{% if port.protocol is defined %}
          protocol: {{ port.protocol }}
{% endif %}
{% endfor %}
{% if nf.privileged | default(false) %}
        securityContext:
          privileged: true
{% endif %}
        env:
{% if nf.db_required | default(true) %}
        - name: DB_URI
          value: "mongodb://mongodb:27017/open5gs"
{% endif %}
{% if nf.extra_env is defined %}
{% for env in nf.extra_env %}
        - name: {{ env.name }}
          value: "{{ env.value }}"
{% endfor %}
{% endif %}
        volumeMounts:
        - name: {{ nf.name }}-config
          mountPath: /etc/open5gs
      volumes:
      - name: {{ nf.name }}-config
        configMap:
          name: {{ nf.name }}-config
{% if nf.setup_script is defined %}
      - name: nf-scripts
        configMap:
          name: nf-scripts
{% endif %}
