apiVersion: apps/v1
kind: Deployment
metadata:
  name: mongodb
  namespace: {{ namespace_5g }}
  annotations:
    checksum/config: "{{ lookup('file', playbook_dir + '/configs/mongodb.conf') | hash('sha256') }}"
    checksum/scripts: "{{ lookup('file', playbook_dir + '/scripts/mongo_init.sh') | hash('sha256') }}"
spec:
  replicas: 1
  strategy:
    # Recreate avoids two pods racing on the same PVC (ReadWriteOnce).
    type: Recreate
    # Explicit null so a strategic-merge patch strips any legacy
    # rollingUpdate block left by a previous RollingUpdate deployment
    # (otherwise the API rejects the patch with "Forbidden: may not be
    # specified when strategy `type` is 'Recreate'").
    rollingUpdate: null
  selector:
    matchLabels:
      app: mongodb
  template:
    metadata:
      labels:
        app: mongodb
    spec:
      nodeSelector:
        kubernetes.io/hostname: worker
      # mongo:6 runs as UID/GID 999 (mongodb user); fsGroup ensures PVC mount is group-accessible
      # when migrating from a root-owned data directory.
      securityContext:
        fsGroup: 999
      containers:
      - name: mongodb
        image: {{ mongodb_image }}
        imagePullPolicy: IfNotPresent
        ports:
        - containerPort: 27017
          name: mongodb
        readinessProbe:
          tcpSocket:
            port: 27017
          initialDelaySeconds: 5
          periodSeconds: 5
          failureThreshold: 12
        livenessProbe:
          tcpSocket:
            port: 27017
          initialDelaySeconds: 30
          periodSeconds: 10
          failureThreshold: 6
        command: ["bash", "/scripts/mongo_init.sh"]
        env:
        - name: SUBSCRIBER_SNAPSHOT_PATH
          value: "/etc/subscribers-snapshot/snapshot.json"
        volumeMounts:
        - name: mongodb-data
          mountPath: /var/lib/mongodb
        - name: mongodb-config
          mountPath: /etc/mongod.conf
          subPath: mongodb.conf
        - name: nf-scripts
          mountPath: /scripts
        - name: mongodb-logs
          mountPath: /var/log/mongodb
        - name: subscribers-snapshot
          mountPath: /etc/subscribers-snapshot
          readOnly: true
      volumes:
      - name: mongodb-config
        configMap:
          name: mongodb-config
      - name: nf-scripts
        configMap:
          name: nf-scripts
      - name: mongodb-logs
        emptyDir: {}
      - name: mongodb-data
        persistentVolumeClaim:
          claimName: {{ mongodb_pvc_name }}
      - name: subscribers-snapshot
        configMap:
          # optional=true so the pod starts even before the subscriber_import role seeds the snapshot
          name: {{ subscriber_snapshot_configmap }}
          optional: true
