apiVersion: apps/v1
kind: Deployment
metadata:
  name: positioning-demo
  namespace: {{ demo_namespace }}
  labels:
    app: positioning-demo
spec:
  replicas: 1
  selector:
    matchLabels:
      app: positioning-demo
  template:
    metadata:
      labels:
        app: positioning-demo
      annotations:
        checksum/config: "{{ lookup('template', role_path + '/templates/demo-config.yaml.j2') | hash('sha256') }}"
    spec:
      nodeSelector:
        kubernetes.io/hostname: worker
      terminationGracePeriodSeconds: 10
      containers:
        - name: positioning-demo
          image: {{ positioning_demo_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 80
              name: http
              protocol: TCP
          readinessProbe:
            httpGet:
              path: /
              port: 80
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 6
          volumeMounts:
            - name: demo-config
              mountPath: /usr/share/nginx/html/env-config.js
              subPath: env-config.js
            - name: demo-config
              mountPath: /etc/nginx/conf.d/default.conf
              subPath: default.conf
      volumes:
        - name: demo-config
          configMap:
            name: positioning-demo-config
