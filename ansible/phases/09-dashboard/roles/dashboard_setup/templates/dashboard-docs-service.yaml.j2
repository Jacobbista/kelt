apiVersion: v1
kind: Service
metadata:
  name: dashboard-docs
  namespace: {{ dashboard_namespace }}
  labels:
    app: dashboard-docs
spec:
  selector:
    app: dashboard-docs
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
      name: http
  # ClusterIP: the frontend reverse-proxies /docs/ to it (same origin).
  type: ClusterIP
