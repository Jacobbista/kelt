apiVersion: v1
kind: ConfigMap
metadata:
  name: dashboard-frontend-config
  namespace: {{ dashboard_namespace }}
data:
  env-config.js: |
    window.__ENV__ = {
      VITE_AUTH_ENABLED: "{{ dashboard_auth_enabled | bool | lower }}",
      VITE_KEYCLOAK_AUTHORITY: "",
      VITE_KEYCLOAK_PATH_PREFIX: "{{ dashboard_keycloak_path_prefix }}",
      VITE_KEYCLOAK_REALM: "{{ dashboard_keycloak_realm }}",
      VITE_KEYCLOAK_CLIENT_ID: "{{ dashboard_keycloak_client_id }}",
      DASHBOARD_DEV_EXTERNAL_URL: "{{ dashboard_dev_external_url if dashboard_dev_external_url else 'http://' ~ hostvars[groups['control'][0]]['ansible_host'] ~ ':' ~ dashboard_frontend_port }}"
    };
  default.conf: |
    server {
      listen 8080 default_server;
      server_name _;
      root /usr/share/nginx/html;
      index index.html;

      # Backend API and WebSockets live on the ansible VM. The pod reverse
      # proxies them so the browser stays on a single origin.
      location /api/ {
        proxy_pass http://{{ hostvars[groups['control'][0]]['ansible_host'] }}:{{ dashboard_backend_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
      }

      location /health {
        proxy_pass http://{{ hostvars[groups['control'][0]]['ansible_host'] }}:{{ dashboard_backend_port }}/health;
      }

      location /watchdog/ {
        proxy_pass http://{{ hostvars[groups['control'][0]]['ansible_host'] }}:{{ dashboard_watchdog_port }}/;
      }

      # The OIDC client redirects the browser back to /auth/callback after
      # Keycloak login. That path is a React route, not a Keycloak endpoint,
      # so it must fall through to the SPA. Exact match wins over the prefix
      # /auth/ block below in nginx matching order.
      location = /auth/callback {
        try_files $uri /index.html;
      }

      # Keycloak lives behind the worker NodePort; same-origin proxy avoids
      # CORS and mixed-content issues when the dashboard is fronted by a
      # tunnel or external reverse proxy.
      location /auth/ {
        proxy_pass http://{{ hostvars[groups['workers'][0]]['ansible_host'] }}:31910/auth/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
      }

      # SPA fallback so client-side routes work on direct hits.
      location / {
        try_files $uri $uri/ /index.html;
      }
    }
