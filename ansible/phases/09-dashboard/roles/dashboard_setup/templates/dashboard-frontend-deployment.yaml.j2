apiVersion: apps/v1
kind: Deployment
metadata:
  name: dashboard-frontend
  namespace: {{ dashboard_namespace }}
  labels:
    app: dashboard-frontend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: dashboard-frontend
  template:
    metadata:
      labels:
        app: dashboard-frontend
      annotations:
        checksum/config: "{{ lookup('template', role_path + '/templates/dashboard-frontend-configmap.yaml.j2') | hash('sha256') }}"
    spec:
      nodeSelector:
        kubernetes.io/hostname: worker
      terminationGracePeriodSeconds: 10
      containers:
        - name: dashboard-frontend
          image: {{ dashboard_frontend_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
              name: http
              protocol: TCP
          readinessProbe:
            httpGet:
              path: /
              port: 8080
            initialDelaySeconds: 3
            periodSeconds: 3
            failureThreshold: 10
          livenessProbe:
            httpGet:
              path: /
              port: 8080
            initialDelaySeconds: 15
            periodSeconds: 10
            failureThreshold: 6
          volumeMounts:
            - name: nginx-conf
              mountPath: /etc/nginx/conf.d/default.conf
              subPath: default.conf
            - name: nginx-conf
              mountPath: /usr/share/nginx/html/env-config.js
              subPath: env-config.js
      volumes:
        - name: nginx-conf
          configMap:
            name: dashboard-frontend-config
