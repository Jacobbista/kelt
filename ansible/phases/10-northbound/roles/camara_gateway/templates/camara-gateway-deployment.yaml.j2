apiVersion: apps/v1
kind: Deployment
metadata:
  name: camara-gateway
  namespace: {{ camara_namespace }}
  labels:
    app: camara-gateway
spec:
  replicas: 1
  selector:
    matchLabels:
      app: camara-gateway
  template:
    metadata:
      labels:
        app: camara-gateway
      annotations:
        checksum/config: "{{ lookup('template', role_path + '/templates/camara-config.yaml.j2') | hash('sha256') }}"
    spec:
      nodeSelector:
        kubernetes.io/hostname: worker
      terminationGracePeriodSeconds: 15
      containers:
        - name: camara-gateway
          image: {{ camara_gateway_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
              name: http
              protocol: TCP
          # Single config mechanism: pod env from a ConfigMap (non-sensitive) and a
          # Secret (sensitive), both optional so a degraded pod still boots and serves
          # /contract. The dashboard guided setup writes these by the contract's
          # `sensitive` flag. See docs/dashboard/modules.md (guided setup).
          envFrom:
            - configMapRef:
                name: camara-config
                optional: true
            - secretRef:
                name: camara-gateway-secrets
                optional: true
          env:
            - name: CAMARA_CLIENT_SECRET
              value: "{{ camara_client_secret }}"
          readinessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 5
            failureThreshold: 12
          livenessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 10
            failureThreshold: 6
