apiVersion: v1
kind: ConfigMap
metadata:
  name: camara-config
  namespace: {{ camara_namespace }}
data:
  SMF_URL: "{{ smf_url }}"
  POSITIONING_ENGINE_URL: "{{ positioning_engine_url }}"
  KEYCLOAK_URL: "http://keycloak.{{ iam_namespace }}.svc.cluster.local:8080{{ keycloak_path_prefix }}"
  KEYCLOAK_REALM: "{{ keycloak_realm }}"
  # Realm role a Bearer token must carry to call the Location endpoints.
  REQUIRED_ROLE: "{{ camara_required_role }}"
  # Development override only: bypasses JWT validation. Keep "false".
  SKIP_AUTH: "{{ camara_skip_auth | string | lower }}"
  # Flat phoneNumber->deviceId map the gateway resolves for CAMARA lookups and
  # exposes via GET /devices. For the richer {phoneNumber,deviceId,label} form,
  # mount a devices.json ConfigMap and set DEVICE_REGISTRY_FILE instead.
  DEVICE_REGISTRY: '{{ camara_device_registry }}'
  # Advertised in the OpenAPI `servers` block and any absolute URL the
  # gateway emits. Operators expose this via reverse proxy (cloudflared,
  # nginx, traefik, etc.) so external clients call a stable hostname.
  CAMARA_EXTERNAL_BASE_URL: "{{ camara_gateway_external_origin }}"
