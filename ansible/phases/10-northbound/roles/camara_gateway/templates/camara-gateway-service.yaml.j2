apiVersion: v1
kind: Service
metadata:
  name: camara-gateway
  namespace: {{ camara_namespace }}
  labels:
    app: camara-gateway
spec:
  selector:
    app: camara-gateway
  ports:
    - protocol: TCP
      port: 8080
      targetPort: 8080
      nodePort: {{ camara_gateway_nodeport }}
      name: http
  type: NodePort
