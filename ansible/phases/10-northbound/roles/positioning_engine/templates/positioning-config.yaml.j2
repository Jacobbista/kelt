apiVersion: v1
kind: ConfigMap
metadata:
  name: positioning-config
  namespace: {{ positioning_namespace }}
data:
  # No static ADAPTER_URLS (v0.6.0): adapters self-register with the engine
  # (POST /adapters) and heartbeat; the engine is the registry authority and
  # evicts dead self-registrations on TTL. ADAPTER_URLS is now only a cold-start
  # SEED the engine reads once when its registry is empty (for off-cluster adapters
  # that cannot self-register); the baseline mock self-registers, so it is unset
  # here. See docs/adapter-registry.md (5g-northbound) and positioning-adapters.md.
{% if engine_adapter_urls %}
  ADAPTER_URLS: "{{ engine_adapter_urls }}"
{% endif %}
  # Optional per-device routing override: CSV of device_id=adapter_name. Empty
  # (default, v0.8.0) = capability-driven routing (the gateway passes the asset's
  # ?source=, the engine fans out to registered adapters and fuses who answers).
  DEVICE_MAP: "{{ engine_device_map }}"
  DEVICE_IDS: "{{ engine_device_ids }}"
  # Classical fusion (no ML). FUSION_COMPARE renders extra strategies side by side.
  FUSION_STRATEGY: "{{ engine_fusion_strategy }}"
  FUSION_COMPARE: "{{ engine_fusion_compare }}"
  WEBSOCKET_INTERVAL_MS: "{{ engine_websocket_interval_ms }}"
  # Engine is the blueprint authority: it persists the blueprint on its PVC
  # (/app/data) and serves GET/PUT /blueprint. This path is read ONCE on cold start
  # (empty PVC) to seed a default room + gps_origin; the editor PUTs the authored
  # blueprint at runtime. See docs/architecture/positioning-adapters.md.
  BLUEPRINT_SEED_PATH: "/app/seed/blueprint.json"
