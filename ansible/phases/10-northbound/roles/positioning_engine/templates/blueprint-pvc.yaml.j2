apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: positioning-blueprint
  namespace: {{ positioning_namespace }}
  labels:
    app: positioning-engine
spec:
  # Engine-owned blueprint store (v0.5.0 model): only the engine mounts this RW at
  # /app/data; the editor PUTs and every other consumer GETs the blueprint over
  # HTTP, so there is no shared PVC. RWO on the default local-path StorageClass is
  # fine because the single mounter (the engine) is pinned to the worker node.
  # See docs/architecture/positioning-adapters.md.
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ positioning_blueprint_pvc_size }}
