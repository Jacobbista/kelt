apiVersion: v1
kind: Service
metadata:
  name: placement-editor
  namespace: {{ positioning_namespace }}
  labels:
    app: placement-editor
spec:
  selector:
    app: placement-editor
  ports:
    - protocol: TCP
      port: 8080
      targetPort: 8080
      name: http
  # ClusterIP only in the baseline. External access is added behind oauth2-proxy
  # with the IAM/edge work; until then reach it with kubectl port-forward.
  type: ClusterIP
