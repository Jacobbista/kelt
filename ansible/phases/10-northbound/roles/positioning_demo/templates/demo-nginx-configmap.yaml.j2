apiVersion: v1
kind: ConfigMap
metadata:
  name: positioning-demo-nginx
  namespace: {{ demo_namespace }}
data:
  # nginx config mounted at /etc/nginx/conf.d/default.conf. This is genuine
  # deployment-specific routing (in-cluster CAMARA proxy), legitimately a file,
  # unlike env-config.js which the entrypoint owns. It MUST keep the /contract
  # location, otherwise this override shadows the image's baked /contract route
  # and the dashboard guided setup cannot read the demo's contract.
  default.conf: |
    # WebSocket upgrade: the demo's live position feed is a WS to the gateway
    # (/positions/stream). Without forwarding Upgrade/Connection the handshake
    # reaches the gateway as a plain GET on a WS route -> 404, device stays OFFLINE.
    map $http_upgrade $connection_upgrade { default upgrade; "" close; }

    server {
      listen 80 default_server;
      server_name _;
      root /usr/share/nginx/html;
      index index.html;

      # Service contract (baked contract.json) for the dashboard guided setup.
      # Exact-match so it wins over the SPA fallback below.
      location = /contract {
        default_type application/json;
        try_files /contract.json =404;
      }

      # CAMARA Location API. Demo code calls `${VITE_CAMARA_API_BASE}/...`
      # so the `/api/camara/` prefix is stripped before forwarding.
      location /api/camara/ {
        proxy_pass http://camara-gateway.{{ camara_namespace | default('camara') }}.svc.cluster.local:8080/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Forward the WebSocket upgrade for the live /positions/stream feed; for
        # plain REST calls $http_upgrade is empty so this stays ordinary HTTP.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
      }

      # SPA fallback for client-side routes.
      location / {
        try_files $uri $uri/ /index.html;
      }
    }
