apiVersion: apps/v1
kind: Deployment
metadata:
  name: positioning-demo
  namespace: {{ demo_namespace }}
  labels:
    app: positioning-demo
spec:
  replicas: 1
  selector:
    matchLabels:
      app: positioning-demo
  template:
    metadata:
      labels:
        app: positioning-demo
      annotations:
        checksum/config: "{{ (lookup('template', role_path + '/templates/demo-config.yaml.j2') ~ lookup('template', role_path + '/templates/demo-nginx-configmap.yaml.j2')) | hash('sha256') }}"
    spec:
      nodeSelector:
        kubernetes.io/hostname: worker
      terminationGracePeriodSeconds: 10
      containers:
        - name: positioning-demo
          image: {{ positioning_demo_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 80
              name: http
              protocol: TCP
          # Browser config as pod env; the image entrypoint renders env-config.js
          # from it. optional so a degraded pod still boots and serves /contract.
          envFrom:
            - configMapRef:
                name: positioning-demo-config
                optional: true
          readinessProbe:
            httpGet:
              path: /
              port: 80
            initialDelaySeconds: 5
            periodSeconds: 5
            failureThreshold: 6
          # Only the nginx config is mounted (legit deployment routing). env-config.js
          # is NOT mounted: the entrypoint owns it (mounting it RO shadows the render).
          volumeMounts:
            - name: demo-nginx
              mountPath: /etc/nginx/conf.d/default.conf
              subPath: default.conf
      volumes:
        - name: demo-nginx
          configMap:
            name: positioning-demo-nginx
