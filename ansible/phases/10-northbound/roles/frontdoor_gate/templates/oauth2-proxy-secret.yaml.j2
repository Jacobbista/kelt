apiVersion: v1
kind: Secret
metadata:
  name: oauth2-proxy-{{ gate_name }}
  namespace: {{ gate_namespace }}
  labels:
    app: oauth2-proxy-{{ gate_name }}
type: Opaque
stringData:
  # client-secret must match the gate's confidential client in phase 08.
  client-secret: "{{ gate_client_secret }}"
  # 16, 24, or 32 bytes. Override the gate's cookie secret for non-lab deploys.
  cookie-secret: "{{ gate_cookie_secret }}"
