apiVersion: v1
kind: Service
metadata:
  name: oauth2-proxy-{{ gate_name }}
  namespace: {{ gate_namespace }}
  labels:
    app: oauth2-proxy-{{ gate_name }}
spec:
  type: NodePort
  selector:
    app: oauth2-proxy-{{ gate_name }}
  ports:
    - protocol: TCP
      port: 4180
      targetPort: 4180
      nodePort: {{ gate_nodeport }}
      name: http
