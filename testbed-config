  # Override via WORKER_LAN_IP env var if a non-default Vagrantfile is used.
  local worker="${WORKER_LAN_IP:-192.168.56.11}"
  local dash_prod="${DASHBOARD_EXTERNAL_ORIGIN:-http://${worker}:31573}"
  local dash_dev="${DASHBOARD_DEV_EXTERNAL_URL:-}"
  local kc_base="${DASHBOARD_KEYCLOAK_EXTERNAL_URL:-http://${worker}:31910}"
  local kc_prefix="${KEYCLOAK_PATH_PREFIX:-}"
  local camara="${CAMARA_GATEWAY_EXTERNAL_ORIGIN:-http://${worker}:31920}"
  local demo="${POSITIONING_DEMO_EXTERNAL_ORIGIN:-http://${worker}:31940}"

  echo ""
  echo "Service endpoints"
  echo "─────────────────"
  printf "  %-22s %s\n" "Dashboard (prod):"  "$dash_prod"
