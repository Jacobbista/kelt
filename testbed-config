interactive_menu() {
  # Checked once per menu entry, not per redraw: check_for_updates only hits the
  # network at most once a day, but the count itself is cheap to keep.
  check_for_updates
  local update_item="Update KELT"
  [[ -n "$UPDATE_BEHIND" ]] && update_item="Update KELT (${UPDATE_BEHIND} available)"

  while true; do
    show_status
    local items=(
      "Deploy        ▸"
      "Configure     ▸"
      "External access ▸"
      "Secrets       ▸"
      "Tests"
      "Show full status"
      "Show service endpoints"
      "Re-run onboarding checks"
      "Install CLI alias + completion"
      "${update_item}"
      "Help"
      "Exit"
    )
    local choice
    choice="$(gum_choose "${items[@]}")"
    case "$choice" in
      "Deploy        ▸")                menu_deploy ;;
      "Configure     ▸")                menu_configure ;;
      "External access ▸")              menu_external_access ;;
      "Secrets       ▸")                menu_secrets ;;
      "Tests")                          do_tests ;;
      "Show full status")               show_status ;;
      "Show service endpoints")         do_endpoints ;;
      "Re-run onboarding checks")       do_onboarding ;;
      "Install CLI alias + completion") do_install_cli ;;
      "Update KELT"*)
        do_update
        # The label carries the pending count, so refresh it after a pull.
        check_for_updates
        update_item="Update KELT"
        [[ -n "$UPDATE_BEHIND" ]] && update_item="Update KELT (${UPDATE_BEHIND} available)"
        ;;
      "Help")                           print_help ;;
      "Exit")                           break ;;
      "")
        # First Esc: ask for confirmation. Block on a single keystroke so
        # the prompt is visible until the user actually answers. Second
        # Esc exits; any other key returns to the menu.
        echo ""
        echo "Press Esc again to exit, or any other key to stay."
        local _key
        IFS= read -rsn1 _key
        # Drain any trailing bytes (arrow keys, F-keys send ESC + seq)
        read -rsn3 -t 0.05 _ 2>/dev/null || true
        if [[ "$_key" == $'\e' ]]; then
          break
        fi
        continue
        ;;
    esac
    # Submenu entries (containing "▸") and Exit/empty skip the pause;
    # everything else waits for the user before redrawing the menu so
    # command output doesn't get steamrolled by the next gum render.
    case "$choice" in
      *"▸"*|"Exit"|"")  ;;
      *)                prompt_continue ;;
    esac
  done
}

# ─── CLI mode ──────────────────────────────────────────────────────────
ONBOARD_MARKER="${HOME}/.config/5g-testbed/onboarded"
AUTOSTART_UNIT="/etc/systemd/system/5g-testbed.service"

is_onboarded() { [[ -f "$ONBOARD_MARKER" ]]; }
mark_onboarded() {
  mkdir -p "$(dirname "$ONBOARD_MARKER")"
  printf 'repo=%s\nat=%s\n' "$SCRIPT_DIR" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$ONBOARD_MARKER"
}

check_item() {
  # check_item "<label>" "<probe command>"
  local label="$1" probe="$2"
  if eval "$probe" >/dev/null 2>&1; then
    printf "  \033[32m✓\033[0m %s\n" "$label"
    return 0
  fi
  printf "  \033[31m✗\033[0m %s\n" "$label"
  return 1
}

do_onboarding() {
  echo ""
  echo "════════════════════════════════════════════════════════════"
  echo "  5G K3s KubeEdge Testbed — Onboarding"
  echo "════════════════════════════════════════════════════════════"
  echo ""
  echo "Tested on Ubuntu 22.04 / 24.04. Auto-fixes use apt; on other"
  echo "distros install the missing packages with your package manager."
  echo ""
  echo "Required:"
  local missing_vagrant=false missing_vbox=false missing_virt=false missing_gum=false
  check_item "vagrant binary"               "command -v vagrant"                  || missing_vagrant=true
  check_item "VirtualBox (vboxmanage)"      "command -v vboxmanage"               || missing_vbox=true
  check_item "CPU virtualization (vmx/svm)" "grep -qE '(vmx|svm)' /proc/cpuinfo"  || missing_virt=true
  check_item "gum (TUI helper)"             "command -v gum"                      || missing_gum=true
  echo ""
  echo "Local config:"
  local missing_env=false missing_alias=false
  check_item "Config file (.testbed.env)"   "[ -f \"$ENV_FILE\" ]"                        || missing_env=true
  check_item "Shell alias 'testbed'"        "grep -q TESTBED_CONFIG_ALIAS \"$HOME/.bashrc\"" || missing_alias=true
  echo ""
  echo "Optional:"
  # vboxusers group is only needed for VirtualBox USB passthrough. Plain VM
  # bring-up works without it, so it is reported as a hint rather than a fail.
  if id -nG | grep -qw vboxusers; then
    printf "  \033[32m✓\033[0m %s\n" "User in vboxusers group (needed only for USB passthrough)"
  else
    printf "  \033[33m·\033[0m %s\n" "User NOT in vboxusers group (only matters for USB passthrough; safe to skip)"
  fi
  echo ""

  if ! $missing_vagrant && ! $missing_vbox && ! $missing_virt \
     && ! $missing_gum && ! $missing_env && ! $missing_alias; then
    echo "All required checks passed."
    mark_onboarded
    return 0
  fi

  read -r -p "Run auto-fixes for the items that can be fixed? [Y/n] " reply
  reply="${reply:-Y}"
  if [[ ! "$reply" =~ ^[yY] ]]; then
    echo "Skipped. Re-run with: testbed-config onboarding"
    return 1
  fi

  if $missing_gum; then
    echo ""
    echo "→ Installing gum via apt..."
    install_gum_apt && HAS_GUM=true || echo "gum install failed (continuing)."
  fi

  if $missing_vagrant || $missing_vbox; then
    echo ""
    echo "→ vagrant / VirtualBox not installed. On Ubuntu/Debian:"
    echo "    sudo apt-get update"
    echo "    sudo apt-get install -y vagrant virtualbox virtualbox-dkms"
    echo "  Then re-run: testbed-config onboarding"
  fi

  if $missing_virt; then
    echo ""
    echo "⚠  CPU virtualization extensions not detected. Enable VT-x/AMD-V in BIOS/UEFI."
  fi

  if $missing_alias; then
    echo ""
    read -r -p "→ Install 'testbed' shell alias + completion? [Y/n] " reply
    reply="${reply:-Y}"
    [[ "$reply" =~ ^[yY] ]] && do_install_cli
  fi

  if $missing_env; then
    echo ""
    read -r -p "→ Initialize config now (set profile)? [Y/n] " reply
    reply="${reply:-Y}"
    [[ "$reply" =~ ^[yY] ]] && do_set_profile
  fi

  echo ""
  echo "Onboarding done. Next steps:"
  echo "  testbed up         # start cluster"
  echo "  testbed            # interactive menu"
  echo "  testbed help       # full reference"
  mark_onboarded
}

