#!/usr/bin/env bash
# testbed-config — Interactive configuration tool for the 5G K3s KubeEdge Testbed
# Uses gum (https://github.com/charmbracelet/gum) for TUI when available.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.testbed.env"
SECRETS_FILE="${SCRIPT_DIR}/.testbed.secrets"
APPLIED_RAN_FILE="${SCRIPT_DIR}/.physical_ran_bridge_applied"

# ─── Defaults ──────────────────────────────────────────────────────────
DEFAULT_PROFILE="laptop"
DEFAULT_EDGE="true"
DEFAULT_DEPLOY_MODE="core_only"
DEFAULT_PHYSICAL_RAN="false"
# Northbound positioning/CAMARA feature (phases 10-12 + placement-editor). Opt-in.
# `testbed northbound on` flips this; all.yml derives camara/positioning/demo/
# placement_editor _enabled from it (see ansible/group_vars/all.yml).
DEFAULT_NORTHBOUND_ENABLED="false"
# Edge apps platform (phase 12: local registry + deploy-from-image + dynamic
# front-door route). Opt-in. `testbed apps on` flips this; all.yml derives
# apps_enabled from it (see ansible/group_vars/all.yml).
DEFAULT_APPS_ENABLED="false"
# Edge apps local registry. Username + host are config; the password is a managed
# secret (.testbed.secrets). Empty host => all.yml derives the worker LAN host:port.
DEFAULT_APPS_REGISTRY_USERNAME="kelt"
DEFAULT_APPS_REGISTRY_HOST=""
DEFAULT_DASHBOARD_DEV_ENABLED="false"
DEFAULT_DASHBOARD_AUTH_ENABLED="true"
# Single base domain for external access. When set, every surface is reached as
# <subdomain>.<base> through the phase 11 front-door behind one Cloudflare wildcard
# (*.<base>); ansible derives all *_external_origin from it. Empty = LAN NodePorts.
DEFAULT_EXTERNAL_BASE_DOMAIN=""
DEFAULT_KEYCLOAK_PATH_PREFIX=""
DEFAULT_DASHBOARD_KEYCLOAK_EXTERNAL_URL=""
DEFAULT_DASHBOARD_KEYCLOAK_PATH_PREFIX=""
DEFAULT_DASHBOARD_EXTERNAL_ORIGIN=""
DEFAULT_DASHBOARD_DEV_EXTERNAL_URL=""
DEFAULT_CAMARA_GATEWAY_EXTERNAL_ORIGIN=""
DEFAULT_POSITIONING_DEMO_EXTERNAL_ORIGIN=""
# Realm reconcile gate for phase 08. Values: ask | true | false.
# 'ask' prompts on every phase 08 launch (interactive only); true/false skips
# the prompt. See docs/security/iam.md.
DEFAULT_KEYCLOAK_REALM_RECONCILE="ask"
DEFAULT_KEYCLOAK_ADMIN_PASSWORD=""
DEFAULT_CAMARA_CLIENT_SECRET=""
DEFAULT_DASHBOARD_READONLY_SECRET=""
DEFAULT_APPS_REGISTRY_PASSWORD=""

# ─── Load persisted config ─────────────────────────────────────────────
load_config() {
  TESTBED_PROFILE="${DEFAULT_PROFILE}"
  EDGE_ENABLED="${DEFAULT_EDGE}"
  DEPLOY_MODE="${DEFAULT_DEPLOY_MODE}"
  PHYSICAL_RAN_ENABLED="${DEFAULT_PHYSICAL_RAN}"
  PHYSICAL_RAN_BRIDGE=""
  NORTHBOUND_ENABLED="${DEFAULT_NORTHBOUND_ENABLED}"
  APPS_ENABLED="${DEFAULT_APPS_ENABLED}"
  APPS_REGISTRY_USERNAME="${DEFAULT_APPS_REGISTRY_USERNAME}"
  APPS_REGISTRY_HOST="${DEFAULT_APPS_REGISTRY_HOST}"
  DASHBOARD_DEV_ENABLED="${DEFAULT_DASHBOARD_DEV_ENABLED}"
  DASHBOARD_AUTH_ENABLED="${DEFAULT_DASHBOARD_AUTH_ENABLED}"
  EXTERNAL_BASE_DOMAIN="${DEFAULT_EXTERNAL_BASE_DOMAIN}"
  KEYCLOAK_PATH_PREFIX="${DEFAULT_KEYCLOAK_PATH_PREFIX}"
  DASHBOARD_KEYCLOAK_EXTERNAL_URL="${DEFAULT_DASHBOARD_KEYCLOAK_EXTERNAL_URL}"
  DASHBOARD_KEYCLOAK_PATH_PREFIX="${DEFAULT_DASHBOARD_KEYCLOAK_PATH_PREFIX}"
  DASHBOARD_EXTERNAL_ORIGIN="${DEFAULT_DASHBOARD_EXTERNAL_ORIGIN}"
  DASHBOARD_DEV_EXTERNAL_URL="${DEFAULT_DASHBOARD_DEV_EXTERNAL_URL}"
  CAMARA_GATEWAY_EXTERNAL_ORIGIN="${DEFAULT_CAMARA_GATEWAY_EXTERNAL_ORIGIN}"
  POSITIONING_DEMO_EXTERNAL_ORIGIN="${DEFAULT_POSITIONING_DEMO_EXTERNAL_ORIGIN}"
  KEYCLOAK_REALM_RECONCILE="${DEFAULT_KEYCLOAK_REALM_RECONCILE}"
  KEYCLOAK_ADMIN_PASSWORD="${DEFAULT_KEYCLOAK_ADMIN_PASSWORD}"
  CAMARA_CLIENT_SECRET="${DEFAULT_CAMARA_CLIENT_SECRET}"
  DASHBOARD_READONLY_SECRET="${DEFAULT_DASHBOARD_READONLY_SECRET}"
  APPS_REGISTRY_PASSWORD="${DEFAULT_APPS_REGISTRY_PASSWORD}"

  if [[ -f "$ENV_FILE" ]]; then
    while IFS='=' read -r key value; do
      [[ -z "$key" || "$key" == \#* ]] && continue
      case "$key" in
        TESTBED_PROFILE)      TESTBED_PROFILE="$value" ;;
        EDGE_ENABLED)         EDGE_ENABLED="$value" ;;
        DEPLOY_MODE)          DEPLOY_MODE="$value" ;;
        PHYSICAL_RAN_ENABLED) PHYSICAL_RAN_ENABLED="$value" ;;
        PHYSICAL_RAN_BRIDGE)  PHYSICAL_RAN_BRIDGE="$value" ;;
        NORTHBOUND_ENABLED)   NORTHBOUND_ENABLED="$value" ;;
        APPS_ENABLED)         APPS_ENABLED="$value" ;;
        APPS_REGISTRY_USERNAME) APPS_REGISTRY_USERNAME="$value" ;;
        APPS_REGISTRY_HOST)   APPS_REGISTRY_HOST="$value" ;;
        DASHBOARD_DEV_ENABLED) DASHBOARD_DEV_ENABLED="$value" ;;
        DASHBOARD_AUTH_ENABLED) DASHBOARD_AUTH_ENABLED="$value" ;;
        EXTERNAL_BASE_DOMAIN) EXTERNAL_BASE_DOMAIN="$value" ;;
        KEYCLOAK_PATH_PREFIX) KEYCLOAK_PATH_PREFIX="$value" ;;
        DASHBOARD_KEYCLOAK_EXTERNAL_URL) DASHBOARD_KEYCLOAK_EXTERNAL_URL="$value" ;;
        DASHBOARD_KEYCLOAK_PATH_PREFIX) DASHBOARD_KEYCLOAK_PATH_PREFIX="$value" ;;
        DASHBOARD_EXTERNAL_ORIGIN) DASHBOARD_EXTERNAL_ORIGIN="$value" ;;
        DASHBOARD_DEV_EXTERNAL_URL) DASHBOARD_DEV_EXTERNAL_URL="$value" ;;
        CAMARA_GATEWAY_EXTERNAL_ORIGIN) CAMARA_GATEWAY_EXTERNAL_ORIGIN="$value" ;;
        POSITIONING_DEMO_EXTERNAL_ORIGIN) POSITIONING_DEMO_EXTERNAL_ORIGIN="$value" ;;
        KEYCLOAK_REALM_RECONCILE) KEYCLOAK_REALM_RECONCILE="$value" ;;
        # Legacy fallback: migrate old .testbed.env secret to .testbed.secrets.
        KEYCLOAK_ADMIN_PASSWORD) KEYCLOAK_ADMIN_PASSWORD="$value" ;;
      esac
    done < "$ENV_FILE"
  fi

  if [[ -f "$SECRETS_FILE" ]]; then
    while IFS='=' read -r key value; do
      [[ -z "$key" || "$key" == \#* ]] && continue
      case "$key" in
        KEYCLOAK_ADMIN_PASSWORD) KEYCLOAK_ADMIN_PASSWORD="$value" ;;
        CAMARA_CLIENT_SECRET) CAMARA_CLIENT_SECRET="$value" ;;
        DASHBOARD_READONLY_SECRET) DASHBOARD_READONLY_SECRET="$value" ;;
        APPS_REGISTRY_PASSWORD) APPS_REGISTRY_PASSWORD="$value" ;;
      esac
    done < "$SECRETS_FILE"
  fi
}

save_config() {
  cat > "$ENV_FILE" << EOF
# Generated by testbed-config — do not edit manually
TESTBED_PROFILE=${TESTBED_PROFILE}
EDGE_ENABLED=${EDGE_ENABLED}
DEPLOY_MODE=${DEPLOY_MODE}
PHYSICAL_RAN_ENABLED=${PHYSICAL_RAN_ENABLED}
PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE}
NORTHBOUND_ENABLED=${NORTHBOUND_ENABLED}
APPS_ENABLED=${APPS_ENABLED}
APPS_REGISTRY_USERNAME=${APPS_REGISTRY_USERNAME}
APPS_REGISTRY_HOST=${APPS_REGISTRY_HOST}
DASHBOARD_DEV_ENABLED=${DASHBOARD_DEV_ENABLED}
DASHBOARD_AUTH_ENABLED=${DASHBOARD_AUTH_ENABLED}
EXTERNAL_BASE_DOMAIN=${EXTERNAL_BASE_DOMAIN}
KEYCLOAK_PATH_PREFIX=${KEYCLOAK_PATH_PREFIX}
DASHBOARD_KEYCLOAK_EXTERNAL_URL=${DASHBOARD_KEYCLOAK_EXTERNAL_URL}
DASHBOARD_KEYCLOAK_PATH_PREFIX=${DASHBOARD_KEYCLOAK_PATH_PREFIX}
DASHBOARD_EXTERNAL_ORIGIN=${DASHBOARD_EXTERNAL_ORIGIN}
DASHBOARD_DEV_EXTERNAL_URL=${DASHBOARD_DEV_EXTERNAL_URL}
CAMARA_GATEWAY_EXTERNAL_ORIGIN=${CAMARA_GATEWAY_EXTERNAL_ORIGIN}
POSITIONING_DEMO_EXTERNAL_ORIGIN=${POSITIONING_DEMO_EXTERNAL_ORIGIN}
KEYCLOAK_REALM_RECONCILE=${KEYCLOAK_REALM_RECONCILE}
EOF
  echo "Configuration saved to .testbed.env"
}

save_secrets() {
  if [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" || -n "${CAMARA_CLIENT_SECRET}" || -n "${DASHBOARD_READONLY_SECRET}" || -n "${APPS_REGISTRY_PASSWORD}" ]]; then
    umask 077
    cat > "$SECRETS_FILE" << EOF
# Generated by testbed-config — secrets
KEYCLOAK_ADMIN_PASSWORD=${KEYCLOAK_ADMIN_PASSWORD}
CAMARA_CLIENT_SECRET=${CAMARA_CLIENT_SECRET}
DASHBOARD_READONLY_SECRET=${DASHBOARD_READONLY_SECRET}
APPS_REGISTRY_PASSWORD=${APPS_REGISTRY_PASSWORD}
EOF
    echo "Secrets saved to .testbed.secrets (0600)."
  else
    rm -f "$SECRETS_FILE"
  fi
}

generate_password() {
  if command -v openssl &>/dev/null; then
    openssl rand -base64 24 | tr -d '\n'
  elif command -v python3 &>/dev/null; then
    python3 -c 'import secrets; print(secrets.token_urlsafe(24))'
  else
    uuidgen | tr -d '-'
  fi
}

ensure_iam_admin_password() {
  if [[ -z "${KEYCLOAK_ADMIN_PASSWORD}" ]]; then
    KEYCLOAK_ADMIN_PASSWORD="$(generate_password)"
    save_secrets
    echo "IAM admin password auto-generated and stored in .testbed.secrets"
  fi
}

auto_generate_missing_secrets() {
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] || KEYCLOAK_ADMIN_PASSWORD="$(generate_password)"
  [[ -n "${CAMARA_CLIENT_SECRET}" ]] || CAMARA_CLIENT_SECRET="$(generate_password)"
  [[ -n "${DASHBOARD_READONLY_SECRET}" ]] || DASHBOARD_READONLY_SECRET="$(generate_password)"
  [[ -n "${APPS_REGISTRY_PASSWORD}" ]] || APPS_REGISTRY_PASSWORD="$(generate_password)"
  save_secrets
}

count_configured_secrets() {
  local n=0
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] && n=$((n + 1))
  [[ -n "${CAMARA_CLIENT_SECRET}" ]] && n=$((n + 1))
  [[ -n "${DASHBOARD_READONLY_SECRET}" ]] && n=$((n + 1))
  [[ -n "${APPS_REGISTRY_PASSWORD}" ]] && n=$((n + 1))
  echo "$n"
}

show_secrets_status() {
  local n
  n="$(count_configured_secrets)"
  echo "Secrets configured: ${n}/4"
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] && echo "  - KEYCLOAK_ADMIN_PASSWORD: set" || echo "  - KEYCLOAK_ADMIN_PASSWORD: unset"
  [[ -n "${CAMARA_CLIENT_SECRET}" ]] && echo "  - CAMARA_CLIENT_SECRET: set" || echo "  - CAMARA_CLIENT_SECRET: unset"
  [[ -n "${DASHBOARD_READONLY_SECRET}" ]] && echo "  - DASHBOARD_READONLY_SECRET: set" || echo "  - DASHBOARD_READONLY_SECRET: unset"
  [[ -n "${APPS_REGISTRY_PASSWORD}" ]] && echo "  - APPS_REGISTRY_PASSWORD: set" || echo "  - APPS_REGISTRY_PASSWORD: unset"
}

set_all_secrets_manually() {
  if $HAS_GUM; then
    KEYCLOAK_ADMIN_PASSWORD="$(gum input --password --placeholder "Keycloak admin password")"
    CAMARA_CLIENT_SECRET="$(gum input --password --placeholder "CAMARA client secret")"
    DASHBOARD_READONLY_SECRET="$(gum input --password --placeholder "Dashboard readonly secret")"
  else
    read -rsp "Keycloak admin password: " KEYCLOAK_ADMIN_PASSWORD; echo ""
    read -rsp "CAMARA client secret: " CAMARA_CLIENT_SECRET; echo ""
    read -rsp "Dashboard readonly secret: " DASHBOARD_READONLY_SECRET; echo ""
  fi
  save_secrets
}

clear_all_secrets() {
  KEYCLOAK_ADMIN_PASSWORD=""
  CAMARA_CLIENT_SECRET=""
  DASHBOARD_READONLY_SECRET=""
  save_secrets
}

do_secrets() {
  local action="${1:-}"
  if [[ -z "$action" ]]; then
    if $HAS_GUM; then
      action="$(gum_choose_or_cancel \
        "Auto-generate missing secrets" \
        "Set all secrets manually" \
        "Rotate all secrets (generate new values)" \
        "Show secrets status" \
        "Clear all secrets")"
      [[ -z "$action" ]] && { echo "Cancelled."; return 0; }
    else
      echo "Usage: $0 secrets generate-missing|manual|rotate|status|clear"
      return 1
    fi
  fi

  case "$action" in
    "Auto-generate missing secrets"|generate-missing)
      auto_generate_missing_secrets
      echo "Missing secrets generated."
      ;;
    "Set all secrets manually"|manual)
      set_all_secrets_manually
      echo "Secrets set manually."
      ;;
    "Rotate all secrets (generate new values)"|rotate)
      KEYCLOAK_ADMIN_PASSWORD="$(generate_password)"
      CAMARA_CLIENT_SECRET="$(generate_password)"
      DASHBOARD_READONLY_SECRET="$(generate_password)"
      save_secrets
      echo "All secrets rotated."
      ;;
    "Show secrets status"|status)
      show_secrets_status
      ;;
    "Clear all secrets"|clear)
      clear_all_secrets
      echo "All secrets cleared."
      ;;
    *)
      echo "Usage: $0 secrets generate-missing|manual|rotate|status|clear"
      return 1
      ;;
  esac
}

ensure_required_secrets_for_provision() {
  if [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" && -n "${CAMARA_CLIENT_SECRET}" && -n "${DASHBOARD_READONLY_SECRET}" ]]; then
    return 0
  fi

  if $HAS_GUM; then
    local action
    action="$(gum choose \
      "Auto-generate missing secrets (recommended)" \
      "Open secrets wizard" \
      "Abort provisioning")"
    case "$action" in
      "Auto-generate missing secrets (recommended)")
        auto_generate_missing_secrets
        ;;
      "Open secrets wizard")
        do_secrets
        ;;
      "Abort provisioning")
        echo "Cancelled."
        return 1
        ;;
    esac
  else
    auto_generate_missing_secrets
  fi

  if [[ -z "${KEYCLOAK_ADMIN_PASSWORD}" || -z "${CAMARA_CLIENT_SECRET}" || -z "${DASHBOARD_READONLY_SECRET}" ]]; then
    echo "Missing required secrets. Run: ./testbed-config secrets"
    return 1
  fi
}

read_applied_ran_bridge() {
  if [[ -f "$APPLIED_RAN_FILE" ]]; then
    tr -d '\n' < "$APPLIED_RAN_FILE"
  fi
}

worker_needs_ran_reload() {
  [[ "$PHYSICAL_RAN_ENABLED" == "true" ]] || return 1
  [[ -n "${PHYSICAL_RAN_BRIDGE}" ]] || return 1

  local applied
  applied="$(read_applied_ran_bridge)"
  [[ "$applied" != "$PHYSICAL_RAN_BRIDGE" ]]
}

# ─── Hardware detection ────────────────────────────────────────────────
detect_hardware() {
  local cpu_threads mem_gb
  cpu_threads="$(nproc 2>/dev/null || echo '?')"
  if command -v free &>/dev/null; then
    mem_gb="$(free -g | awk '/^Mem:/{print $2}')"
  else
    mem_gb="?"
  fi
  echo "${cpu_threads} threads, ${mem_gb} GB RAM"
}

suggest_profile() {
  local threads
  threads="$(nproc 2>/dev/null || echo 0)"
  if (( threads <= 8 )); then
    echo "server"
  else
    echo "laptop"
  fi
}

# ─── gum helpers ───────────────────────────────────────────────────────
HAS_GUM=false
command -v gum &>/dev/null && HAS_GUM=true

gum_or_echo() {
  if $HAS_GUM; then
    gum style --border rounded --padding "1 2" --border-foreground 39 "$@"
  else
    echo "═══════════════════════════════════════"
    printf '%s\n' "$@"
    echo "═══════════════════════════════════════"
  fi
}

gum_choose() {
  # gum choose exits non-zero on Esc (nothing selected). With `set -e`
  # active, that would kill the whole script, so swallow the failure
  # and return an empty stdout to let callers detect cancellation.
  if $HAS_GUM; then
    gum choose "$@" || true
  else
    select choice in "$@"; do
      echo "$choice"
      return
    done
  fi
}

# Like gum_choose, but always appends a "← Cancel" item and returns an
# empty string when the user cancels (either by selecting it or pressing
# Esc, which gum already maps to empty). Lets every action function
# bail out cleanly without committing to a choice.
gum_choose_or_cancel() {
  local result
  result="$(gum_choose "$@" "← Cancel")"
  [[ "$result" == "← Cancel" ]] && return 0
  printf '%s\n' "$result"
}

prompt_continue() {
  echo ""
  read -rsp "↵ Press Enter to return to menu... " _ || true
  echo ""
}

gum_confirm() {
  if $HAS_GUM; then
    gum confirm "$@"
  else
    read -rp "$* [y/N] " answer
    [[ "$answer" =~ ^[Yy] ]]
  fi
}

# ─── Display ───────────────────────────────────────────────────────────
show_status() {
  local hw
  hw="$(detect_hardware)"
  local edge_label
  [[ "$EDGE_ENABLED" == "true" ]] && edge_label="enabled" || edge_label="disabled"
  local ran_label
  [[ "$PHYSICAL_RAN_ENABLED" == "true" ]] && ran_label="${PHYSICAL_RAN_BRIDGE:-auto}" || ran_label="disabled"

  local ueransim_label
  if [[ "$EDGE_ENABLED" == "true" ]]; then
    [[ "$DEPLOY_MODE" == "full" ]] && ueransim_label="enabled" || ueransim_label="disabled"
  else
    ueransim_label="—  (requires edge)"
  fi
  local iam_admin_label
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] && iam_admin_label="configured" || iam_admin_label="unset"
  local auth_label
  [[ "${DASHBOARD_AUTH_ENABLED}" == "true" ]] && auth_label="enabled" || auth_label="disabled"
  local secrets_label
  secrets_label="$(count_configured_secrets)/3"
  local prod_url_label
  prod_url_label="${DASHBOARD_EXTERNAL_ORIGIN:-unset}"
  local dev_url_label
  dev_url_label="${DASHBOARD_DEV_EXTERNAL_URL:-unset}"
  local camara_url_label
  camara_url_label="${CAMARA_GATEWAY_EXTERNAL_ORIGIN:-unset}"

  if $HAS_GUM; then
    gum style --border rounded --padding "1 2" --border-foreground 39 \
      "5G K3s KubeEdge Testbed" \
      "────────────────────────" \
      "Hardware:  ${hw}" \
      "Profile:   ${TESTBED_PROFILE}" \
      "Edge VM:   ${edge_label}" \
      "UERANSIM:  ${ueransim_label}" \
      "RAN:       ${ran_label}" \
      "Dev front: ${DASHBOARD_DEV_ENABLED}" \
      "Prod URL:  ${prod_url_label}" \
      "Dev URL:   ${dev_url_label}" \
      "CAMARA:    ${camara_url_label}" \
      "Auth:      ${auth_label}" \
      "IAM admin: ${iam_admin_label}" \
      "Secrets:   ${secrets_label}"
  else
    echo ""
    echo "  5G K3s KubeEdge Testbed"
    echo "  ────────────────────────"
    echo "  Hardware:  ${hw}"
    echo "  Profile:   ${TESTBED_PROFILE}"
    echo "  Edge VM:   ${edge_label}"
    echo "  UERANSIM:  ${ueransim_label}"
    echo "  RAN:       ${ran_label}"
    echo "  Dev front: ${DASHBOARD_DEV_ENABLED}"
    echo "  Prod URL:  ${prod_url_label}"
    echo "  Dev URL:   ${dev_url_label}"
    echo "  CAMARA:    ${camara_url_label}"
    echo "  Auth:      ${auth_label}"
    echo "  IAM admin: ${iam_admin_label}"
    echo "  Secrets:   ${secrets_label}"
    echo ""
  fi
}

# ─── Actions ───────────────────────────────────────────────────────────
do_set_profile() {
  local profile="${1:-}"
  if [[ -z "$profile" ]]; then
    echo ""
    echo "  laptop  — 4 VMs (18 vCPU, 17 GB) with edge (current default)"
    echo "  server  — 3 VMs (7 vCPU, 14 GB) no edge, optimized for NUC/server"
    echo ""
    profile="$(gum_choose_or_cancel "laptop" "server")"
    [[ -z "$profile" ]] && { echo "Cancelled."; return 0; }
  fi
  case "$profile" in
    laptop|server) TESTBED_PROFILE="$profile" ;;
    *) echo "Unknown profile: $profile (valid: laptop, server)"; return 1 ;;
  esac
  # Adjust edge and deploy mode per profile
  if [[ "$TESTBED_PROFILE" == "server" ]]; then
    EDGE_ENABLED="false"
    DEPLOY_MODE="core_only"
  else
    EDGE_ENABLED="true"
  fi
  save_config
  echo "Profile set to: ${TESTBED_PROFILE} (edge: ${EDGE_ENABLED}, deploy: ${DEPLOY_MODE})"
}

do_edge() {
  local toggle="${1:-}"
  if [[ -z "$toggle" ]]; then
    if gum_confirm "Enable edge VM?"; then
      toggle="on"
    else
      toggle="off"
    fi
  fi
  case "$toggle" in
    on|true)
      EDGE_ENABLED="true"
      # Ask whether to also deploy UERANSIM on the edge
      if [[ "$DEPLOY_MODE" != "full" ]]; then
        if gum_confirm "Also deploy UERANSIM on edge? (full mode)"; then
          DEPLOY_MODE="full"
        fi
      fi
      ;;
    off|false)
      EDGE_ENABLED="false"
      DEPLOY_MODE="core_only"
      ;;
    *) echo "Usage: $0 edge on|off"; return 1 ;;
  esac
  save_config
  echo "Edge VM: ${EDGE_ENABLED} (deploy: ${DEPLOY_MODE})"
}

do_set_northbound() {
  # One command to turn the whole northbound positioning/CAMARA feature on or off.
  # Flips NORTHBOUND_ENABLED in .testbed.env; all.yml derives camara_enabled,
  # positioning_enabled, positioning_demo_enabled and placement_editor_enabled
  # from it, and phase 08 emits the matching realm objects. See docs/status.md.
  local toggle="${1:-}"
  if [[ -z "$toggle" ]]; then
    if gum_confirm "Enable the northbound positioning/CAMARA feature (phases 10-12 + placement-editor)?"; then
      toggle="on"
    else
      toggle="off"
    fi
  fi
  case "$toggle" in
    on|true)  NORTHBOUND_ENABLED="true" ;;
    off|false) NORTHBOUND_ENABLED="false" ;;
    *) echo "Usage: $0 northbound on|off"; return 1 ;;
  esac
  save_config
  echo "Northbound feature: ${NORTHBOUND_ENABLED} (camara + positioning + demo + placement-editor)"
  if [[ "$NORTHBOUND_ENABLED" == "true" ]]; then
    echo "Apply with: testbed provision   (or: testbed run-phase 08-iam / 10-northbound)"
    echo "NOTE: Keycloak imports the realm only once. On an already-provisioned cluster the new"
    echo "      camara/positioning/placement clients are NOT auto-created; re-import the realm or add"
    echo "      them via the admin console. See docs/security/iam.md (realm reconcile limitation)."
  fi
}

do_set_apps() {
  # One command to turn the edge apps platform (phase 12) on or off. Flips
  # APPS_ENABLED in .testbed.env; all.yml derives apps_enabled from it, which
  # deploys the local registry + apps namespace and emits the front-door dynamic
  # route. See docs/architecture/edge-apps.md.
  local toggle="${1:-}"
  if [[ -z "$toggle" ]]; then
    if gum_confirm "Enable the edge apps platform (local registry + deploy-from-image)?"; then
      toggle="on"
    else
      toggle="off"
    fi
  fi
  case "$toggle" in
    on|true)  APPS_ENABLED="true" ;;
    off|false) APPS_ENABLED="false" ;;
    *) echo "Usage: $0 apps on|off"; return 1 ;;
  esac
  save_config
  echo "Edge apps platform: ${APPS_ENABLED} (local registry + dynamic <name>.<base> route)"
  if [[ "$APPS_ENABLED" == "true" ]]; then
    echo "Apply with: testbed provision   (or: testbed run-phase 12-apps, then re-run 11-frontdoor)"
    echo "NOTE: phase 12 writes /etc/rancher/k3s/registries.yaml on the worker and restarts k3s"
    echo "      on the worker only when that file changes. See docs/architecture/edge-apps.md."
  fi
}

