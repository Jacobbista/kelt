#!/usr/bin/env bash
# testbed-config — Interactive configuration tool for the 5G K3s KubeEdge Testbed
# Uses gum (https://github.com/charmbracelet/gum) for TUI when available.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.testbed.env"
SECRETS_FILE="${SCRIPT_DIR}/.testbed.secrets"
APPLIED_RAN_FILE="${SCRIPT_DIR}/.physical_ran_bridge_applied"

# ─── Defaults ──────────────────────────────────────────────────────────
DEFAULT_PROFILE="laptop"
DEFAULT_EDGE="true"
DEFAULT_DEPLOY_MODE="core_only"
DEFAULT_PHYSICAL_RAN="false"
DEFAULT_DASHBOARD_DEV_ENABLED="false"
DEFAULT_DASHBOARD_AUTH_ENABLED="true"
DEFAULT_KEYCLOAK_PATH_PREFIX=""
DEFAULT_DASHBOARD_KEYCLOAK_EXTERNAL_URL=""
DEFAULT_DASHBOARD_KEYCLOAK_PATH_PREFIX=""
DEFAULT_DASHBOARD_EXTERNAL_ORIGIN=""
DEFAULT_DASHBOARD_DEV_EXTERNAL_URL=""
DEFAULT_POSITIONING_DEMO_EXTERNAL_ORIGIN=""
DEFAULT_KEYCLOAK_ADMIN_PASSWORD=""
DEFAULT_CAMARA_CLIENT_SECRET=""
DEFAULT_DASHBOARD_READONLY_SECRET=""

# ─── Load persisted config ─────────────────────────────────────────────
load_config() {
  TESTBED_PROFILE="${DEFAULT_PROFILE}"
  EDGE_ENABLED="${DEFAULT_EDGE}"
  DEPLOY_MODE="${DEFAULT_DEPLOY_MODE}"
  PHYSICAL_RAN_ENABLED="${DEFAULT_PHYSICAL_RAN}"
  PHYSICAL_RAN_BRIDGE=""
  DASHBOARD_DEV_ENABLED="${DEFAULT_DASHBOARD_DEV_ENABLED}"
  DASHBOARD_AUTH_ENABLED="${DEFAULT_DASHBOARD_AUTH_ENABLED}"
  KEYCLOAK_PATH_PREFIX="${DEFAULT_KEYCLOAK_PATH_PREFIX}"
  DASHBOARD_KEYCLOAK_EXTERNAL_URL="${DEFAULT_DASHBOARD_KEYCLOAK_EXTERNAL_URL}"
  DASHBOARD_KEYCLOAK_PATH_PREFIX="${DEFAULT_DASHBOARD_KEYCLOAK_PATH_PREFIX}"
  DASHBOARD_EXTERNAL_ORIGIN="${DEFAULT_DASHBOARD_EXTERNAL_ORIGIN}"
  DASHBOARD_DEV_EXTERNAL_URL="${DEFAULT_DASHBOARD_DEV_EXTERNAL_URL}"
  POSITIONING_DEMO_EXTERNAL_ORIGIN="${DEFAULT_POSITIONING_DEMO_EXTERNAL_ORIGIN}"
  KEYCLOAK_ADMIN_PASSWORD="${DEFAULT_KEYCLOAK_ADMIN_PASSWORD}"
  CAMARA_CLIENT_SECRET="${DEFAULT_CAMARA_CLIENT_SECRET}"
  DASHBOARD_READONLY_SECRET="${DEFAULT_DASHBOARD_READONLY_SECRET}"

  if [[ -f "$ENV_FILE" ]]; then
    while IFS='=' read -r key value; do
      [[ -z "$key" || "$key" == \#* ]] && continue
      case "$key" in
        TESTBED_PROFILE)      TESTBED_PROFILE="$value" ;;
        EDGE_ENABLED)         EDGE_ENABLED="$value" ;;
        DEPLOY_MODE)          DEPLOY_MODE="$value" ;;
        PHYSICAL_RAN_ENABLED) PHYSICAL_RAN_ENABLED="$value" ;;
        PHYSICAL_RAN_BRIDGE)  PHYSICAL_RAN_BRIDGE="$value" ;;
        DASHBOARD_DEV_ENABLED) DASHBOARD_DEV_ENABLED="$value" ;;
        DASHBOARD_AUTH_ENABLED) DASHBOARD_AUTH_ENABLED="$value" ;;
        KEYCLOAK_PATH_PREFIX) KEYCLOAK_PATH_PREFIX="$value" ;;
        DASHBOARD_KEYCLOAK_EXTERNAL_URL) DASHBOARD_KEYCLOAK_EXTERNAL_URL="$value" ;;
        DASHBOARD_KEYCLOAK_PATH_PREFIX) DASHBOARD_KEYCLOAK_PATH_PREFIX="$value" ;;
        DASHBOARD_EXTERNAL_ORIGIN) DASHBOARD_EXTERNAL_ORIGIN="$value" ;;
        DASHBOARD_DEV_EXTERNAL_URL) DASHBOARD_DEV_EXTERNAL_URL="$value" ;;
        POSITIONING_DEMO_EXTERNAL_ORIGIN) POSITIONING_DEMO_EXTERNAL_ORIGIN="$value" ;;
        # Legacy fallback: migrate old .testbed.env secret to .testbed.secrets.
        KEYCLOAK_ADMIN_PASSWORD) KEYCLOAK_ADMIN_PASSWORD="$value" ;;
      esac
    done < "$ENV_FILE"
  fi

  if [[ -f "$SECRETS_FILE" ]]; then
    while IFS='=' read -r key value; do
      [[ -z "$key" || "$key" == \#* ]] && continue
      case "$key" in
        KEYCLOAK_ADMIN_PASSWORD) KEYCLOAK_ADMIN_PASSWORD="$value" ;;
        CAMARA_CLIENT_SECRET) CAMARA_CLIENT_SECRET="$value" ;;
        DASHBOARD_READONLY_SECRET) DASHBOARD_READONLY_SECRET="$value" ;;
      esac
    done < "$SECRETS_FILE"
  fi
}

save_config() {
  cat > "$ENV_FILE" << EOF
# Generated by testbed-config — do not edit manually
TESTBED_PROFILE=${TESTBED_PROFILE}
EDGE_ENABLED=${EDGE_ENABLED}
DEPLOY_MODE=${DEPLOY_MODE}
PHYSICAL_RAN_ENABLED=${PHYSICAL_RAN_ENABLED}
PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE}
DASHBOARD_DEV_ENABLED=${DASHBOARD_DEV_ENABLED}
DASHBOARD_AUTH_ENABLED=${DASHBOARD_AUTH_ENABLED}
KEYCLOAK_PATH_PREFIX=${KEYCLOAK_PATH_PREFIX}
DASHBOARD_KEYCLOAK_EXTERNAL_URL=${DASHBOARD_KEYCLOAK_EXTERNAL_URL}
DASHBOARD_KEYCLOAK_PATH_PREFIX=${DASHBOARD_KEYCLOAK_PATH_PREFIX}
DASHBOARD_EXTERNAL_ORIGIN=${DASHBOARD_EXTERNAL_ORIGIN}
DASHBOARD_DEV_EXTERNAL_URL=${DASHBOARD_DEV_EXTERNAL_URL}
POSITIONING_DEMO_EXTERNAL_ORIGIN=${POSITIONING_DEMO_EXTERNAL_ORIGIN}
EOF
  echo "Configuration saved to .testbed.env"
}

save_secrets() {
  if [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" || -n "${CAMARA_CLIENT_SECRET}" || -n "${DASHBOARD_READONLY_SECRET}" ]]; then
    umask 077
    cat > "$SECRETS_FILE" << EOF
# Generated by testbed-config — secrets
KEYCLOAK_ADMIN_PASSWORD=${KEYCLOAK_ADMIN_PASSWORD}
CAMARA_CLIENT_SECRET=${CAMARA_CLIENT_SECRET}
DASHBOARD_READONLY_SECRET=${DASHBOARD_READONLY_SECRET}
EOF
    echo "Secrets saved to .testbed.secrets (0600)."
  else
    rm -f "$SECRETS_FILE"
  fi
}

generate_password() {
  if command -v openssl &>/dev/null; then
    openssl rand -base64 24 | tr -d '\n'
  elif command -v python3 &>/dev/null; then
    python3 -c 'import secrets; print(secrets.token_urlsafe(24))'
  else
    uuidgen | tr -d '-'
  fi
}

ensure_iam_admin_password() {
  if [[ -z "${KEYCLOAK_ADMIN_PASSWORD}" ]]; then
    KEYCLOAK_ADMIN_PASSWORD="$(generate_password)"
    save_secrets
    echo "IAM admin password auto-generated and stored in .testbed.secrets"
  fi
}

auto_generate_missing_secrets() {
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] || KEYCLOAK_ADMIN_PASSWORD="$(generate_password)"
  [[ -n "${CAMARA_CLIENT_SECRET}" ]] || CAMARA_CLIENT_SECRET="$(generate_password)"
  [[ -n "${DASHBOARD_READONLY_SECRET}" ]] || DASHBOARD_READONLY_SECRET="$(generate_password)"
  save_secrets
}

count_configured_secrets() {
  local n=0
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] && n=$((n + 1))
  [[ -n "${CAMARA_CLIENT_SECRET}" ]] && n=$((n + 1))
  [[ -n "${DASHBOARD_READONLY_SECRET}" ]] && n=$((n + 1))
  echo "$n"
}

show_secrets_status() {
  local n
  n="$(count_configured_secrets)"
  echo "Secrets configured: ${n}/3"
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] && echo "  - KEYCLOAK_ADMIN_PASSWORD: set" || echo "  - KEYCLOAK_ADMIN_PASSWORD: unset"
  [[ -n "${CAMARA_CLIENT_SECRET}" ]] && echo "  - CAMARA_CLIENT_SECRET: set" || echo "  - CAMARA_CLIENT_SECRET: unset"
  [[ -n "${DASHBOARD_READONLY_SECRET}" ]] && echo "  - DASHBOARD_READONLY_SECRET: set" || echo "  - DASHBOARD_READONLY_SECRET: unset"
}

set_all_secrets_manually() {
  if $HAS_GUM; then
    KEYCLOAK_ADMIN_PASSWORD="$(gum input --password --placeholder "Keycloak admin password")"
    CAMARA_CLIENT_SECRET="$(gum input --password --placeholder "CAMARA client secret")"
    DASHBOARD_READONLY_SECRET="$(gum input --password --placeholder "Dashboard readonly secret")"
  else
    read -rsp "Keycloak admin password: " KEYCLOAK_ADMIN_PASSWORD; echo ""
    read -rsp "CAMARA client secret: " CAMARA_CLIENT_SECRET; echo ""
    read -rsp "Dashboard readonly secret: " DASHBOARD_READONLY_SECRET; echo ""
  fi
  save_secrets
}

clear_all_secrets() {
  KEYCLOAK_ADMIN_PASSWORD=""
  CAMARA_CLIENT_SECRET=""
  DASHBOARD_READONLY_SECRET=""
  save_secrets
}

do_secrets() {
  local action="${1:-}"
  if [[ -z "$action" ]]; then
    if $HAS_GUM; then
      action="$(gum choose \
        "Auto-generate missing secrets" \
        "Set all secrets manually" \
        "Rotate all secrets (generate new values)" \
        "Show secrets status" \
        "Clear all secrets")"
    else
      echo "Usage: $0 secrets generate-missing|manual|rotate|status|clear"
      return 1
    fi
  fi

  case "$action" in
    "Auto-generate missing secrets"|generate-missing)
      auto_generate_missing_secrets
      echo "Missing secrets generated."
      ;;
    "Set all secrets manually"|manual)
      set_all_secrets_manually
      echo "Secrets set manually."
      ;;
    "Rotate all secrets (generate new values)"|rotate)
      KEYCLOAK_ADMIN_PASSWORD="$(generate_password)"
      CAMARA_CLIENT_SECRET="$(generate_password)"
      DASHBOARD_READONLY_SECRET="$(generate_password)"
      save_secrets
      echo "All secrets rotated."
      ;;
    "Show secrets status"|status)
      show_secrets_status
      ;;
    "Clear all secrets"|clear)
      clear_all_secrets
      echo "All secrets cleared."
      ;;
    *)
      echo "Usage: $0 secrets generate-missing|manual|rotate|status|clear"
      return 1
      ;;
  esac
}

ensure_required_secrets_for_provision() {
  if [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" && -n "${CAMARA_CLIENT_SECRET}" && -n "${DASHBOARD_READONLY_SECRET}" ]]; then
    return 0
  fi

  if $HAS_GUM; then
    local action
    action="$(gum choose \
      "Auto-generate missing secrets (recommended)" \
      "Open secrets wizard" \
      "Abort provisioning")"
    case "$action" in
      "Auto-generate missing secrets (recommended)")
        auto_generate_missing_secrets
        ;;
      "Open secrets wizard")
        do_secrets
        ;;
      "Abort provisioning")
        echo "Cancelled."
        return 1
        ;;
    esac
  else
    auto_generate_missing_secrets
  fi

  if [[ -z "${KEYCLOAK_ADMIN_PASSWORD}" || -z "${CAMARA_CLIENT_SECRET}" || -z "${DASHBOARD_READONLY_SECRET}" ]]; then
    echo "Missing required secrets. Run: ./testbed-config secrets"
    return 1
  fi
}

read_applied_ran_bridge() {
  if [[ -f "$APPLIED_RAN_FILE" ]]; then
    tr -d '\n' < "$APPLIED_RAN_FILE"
  fi
}

worker_needs_ran_reload() {
  [[ "$PHYSICAL_RAN_ENABLED" == "true" ]] || return 1
  [[ -n "${PHYSICAL_RAN_BRIDGE}" ]] || return 1

  local applied
  applied="$(read_applied_ran_bridge)"
  [[ "$applied" != "$PHYSICAL_RAN_BRIDGE" ]]
}

# ─── Hardware detection ────────────────────────────────────────────────
detect_hardware() {
  local cpu_threads mem_gb
  cpu_threads="$(nproc 2>/dev/null || echo '?')"
  if command -v free &>/dev/null; then
    mem_gb="$(free -g | awk '/^Mem:/{print $2}')"
  else
    mem_gb="?"
  fi
  echo "${cpu_threads} threads, ${mem_gb} GB RAM"
}

suggest_profile() {
  local threads
  threads="$(nproc 2>/dev/null || echo 0)"
  if (( threads <= 8 )); then
    echo "server"
  else
    echo "laptop"
  fi
}

# ─── gum helpers ───────────────────────────────────────────────────────
HAS_GUM=false
command -v gum &>/dev/null && HAS_GUM=true

gum_or_echo() {
  if $HAS_GUM; then
    gum style --border rounded --padding "1 2" --border-foreground 39 "$@"
  else
    echo "═══════════════════════════════════════"
    printf '%s\n' "$@"
    echo "═══════════════════════════════════════"
  fi
}

gum_choose() {
  if $HAS_GUM; then
    gum choose "$@"
  else
    select choice in "$@"; do
      echo "$choice"
      return
    done
  fi
}

gum_confirm() {
  if $HAS_GUM; then
    gum confirm "$@"
  else
    read -rp "$* [y/N] " answer
    [[ "$answer" =~ ^[Yy] ]]
  fi
}

# ─── Display ───────────────────────────────────────────────────────────
show_status() {
  local hw
  hw="$(detect_hardware)"
  local edge_label
  [[ "$EDGE_ENABLED" == "true" ]] && edge_label="enabled" || edge_label="disabled"
  local ran_label
  [[ "$PHYSICAL_RAN_ENABLED" == "true" ]] && ran_label="${PHYSICAL_RAN_BRIDGE:-auto}" || ran_label="disabled"

  local ueransim_label
  if [[ "$EDGE_ENABLED" == "true" ]]; then
    [[ "$DEPLOY_MODE" == "full" ]] && ueransim_label="enabled" || ueransim_label="disabled"
  else
    ueransim_label="—  (requires edge)"
  fi
  local iam_admin_label
  [[ -n "${KEYCLOAK_ADMIN_PASSWORD}" ]] && iam_admin_label="configured" || iam_admin_label="unset"
  local auth_label
  [[ "${DASHBOARD_AUTH_ENABLED}" == "true" ]] && auth_label="enabled" || auth_label="disabled"
  local secrets_label
  secrets_label="$(count_configured_secrets)/3"
  local prod_url_label
  prod_url_label="${DASHBOARD_EXTERNAL_ORIGIN:-unset}"
  local dev_url_label
  dev_url_label="${DASHBOARD_DEV_EXTERNAL_URL:-unset}"

  if $HAS_GUM; then
    gum style --border rounded --padding "1 2" --border-foreground 39 \
      "5G K3s KubeEdge Testbed" \
      "────────────────────────" \
      "Hardware:  ${hw}" \
      "Profile:   ${TESTBED_PROFILE}" \
      "Edge VM:   ${edge_label}" \
      "UERANSIM:  ${ueransim_label}" \
      "RAN:       ${ran_label}" \
      "Dev front: ${DASHBOARD_DEV_ENABLED}" \
      "Prod URL:  ${prod_url_label}" \
      "Dev URL:   ${dev_url_label}" \
      "Auth:      ${auth_label}" \
      "IAM admin: ${iam_admin_label}" \
      "Secrets:   ${secrets_label}"
  else
    echo ""
    echo "  5G K3s KubeEdge Testbed"
    echo "  ────────────────────────"
    echo "  Hardware:  ${hw}"
    echo "  Profile:   ${TESTBED_PROFILE}"
    echo "  Edge VM:   ${edge_label}"
    echo "  UERANSIM:  ${ueransim_label}"
    echo "  RAN:       ${ran_label}"
    echo "  Dev front: ${DASHBOARD_DEV_ENABLED}"
    echo "  Prod URL:  ${prod_url_label}"
    echo "  Dev URL:   ${dev_url_label}"
    echo "  Auth:      ${auth_label}"
    echo "  IAM admin: ${iam_admin_label}"
    echo "  Secrets:   ${secrets_label}"
    echo ""
  fi
}

# ─── Actions ───────────────────────────────────────────────────────────
do_set_profile() {
  local profile="${1:-}"
  if [[ -z "$profile" ]]; then
    echo ""
    echo "  laptop  — 4 VMs (18 vCPU, 17 GB) with edge (current default)"
    echo "  server  — 3 VMs (7 vCPU, 14 GB) no edge, optimized for NUC/server"
    echo ""
    profile="$(gum_choose "laptop" "server")"
  fi
  case "$profile" in
    laptop|server) TESTBED_PROFILE="$profile" ;;
    *) echo "Unknown profile: $profile (valid: laptop, server)"; return 1 ;;
  esac
  # Adjust edge and deploy mode per profile
  if [[ "$TESTBED_PROFILE" == "server" ]]; then
    EDGE_ENABLED="false"
    DEPLOY_MODE="core_only"
  else
    EDGE_ENABLED="true"
  fi
  save_config
  echo "Profile set to: ${TESTBED_PROFILE} (edge: ${EDGE_ENABLED}, deploy: ${DEPLOY_MODE})"
}

do_edge() {
  local toggle="${1:-}"
  if [[ -z "$toggle" ]]; then
    if gum_confirm "Enable edge VM?"; then
      toggle="on"
    else
      toggle="off"
    fi
  fi
  case "$toggle" in
    on|true)
      EDGE_ENABLED="true"
      # Ask whether to also deploy UERANSIM on the edge
      if [[ "$DEPLOY_MODE" != "full" ]]; then
        if gum_confirm "Also deploy UERANSIM on edge? (full mode)"; then
          DEPLOY_MODE="full"
        fi
      fi
      ;;
    off|false)
      EDGE_ENABLED="false"
      DEPLOY_MODE="core_only"
      ;;
    *) echo "Usage: $0 edge on|off"; return 1 ;;
  esac
  save_config
  echo "Edge VM: ${EDGE_ENABLED} (deploy: ${DEPLOY_MODE})"
}

do_ran() {
  local nic="${1:-}"
  if [[ -z "$nic" ]]; then
    echo ""
    echo "Available network interfaces:"
    local nics
    nics="$(ip -o link show | awk -F': ' '{print $2}' | grep -v '^lo$')"
    echo "$nics"
    echo ""
    nic="$(echo "$nics" | gum_choose)"
  fi
  if [[ -z "$nic" || "$nic" == "disable" ]]; then
    PHYSICAL_RAN_ENABLED="false"
    PHYSICAL_RAN_BRIDGE=""
  else
    PHYSICAL_RAN_ENABLED="true"
    PHYSICAL_RAN_BRIDGE="$nic"
  fi
  save_config
  echo "Physical RAN: ${PHYSICAL_RAN_ENABLED} (bridge: ${PHYSICAL_RAN_BRIDGE:-none})"
}

do_set_dashboard_dev_enabled() {
  # Dashboard cluster pod is the always-on baseline (worker NodePort). The
  # Vite dev frontend on the ansible VM is an opt-in extra layered on top
  # for live frontend development. Both can coexist on different IPs.
  local value="${1:-}"
  if [[ -z "$value" ]]; then
    value="$(gum_choose "true" "false")"
  fi
  case "$value" in
    true|on|enabled)   DASHBOARD_DEV_ENABLED="true" ;;
    false|off|disabled) DASHBOARD_DEV_ENABLED="false" ;;
    *) echo "Usage: $0 dashboard-dev true|false"; return 1 ;;
  esac
  save_config
  echo "Dashboard dev frontend: ${DASHBOARD_DEV_ENABLED}"
}

do_set_dashboard_auth() {
  local value="${1:-}"
  if [[ -z "$value" ]]; then
    value="$(gum_choose "enabled" "disabled")"
  fi
  case "$value" in
    enabled|true) DASHBOARD_AUTH_ENABLED="true" ;;
    disabled|false) DASHBOARD_AUTH_ENABLED="false" ;;
    *) echo "Usage: $0 dashboard-auth enabled|disabled"; return 1 ;;
  esac
  save_config
  echo "Dashboard auth: ${DASHBOARD_AUTH_ENABLED}"
}

do_set_external_origin() {
  local origin="${1:-}"
  if [[ -z "$origin" ]]; then
    if $HAS_GUM; then
      origin="$(gum input --placeholder "https://core.example.com")"
    else
      read -rp "Dashboard external origin (https://...): " origin
    fi
  fi
  DASHBOARD_EXTERNAL_ORIGIN="$origin"
  save_config
  echo "Dashboard external origin set."
}

do_set_positioning_origin() {
  local origin="${1:-}"
  if [[ -z "$origin" ]]; then
    if $HAS_GUM; then
      origin="$(gum input --placeholder "https://core.example.com")"
    else
      read -rp "Positioning demo external origin (https://...): " origin
    fi
  fi
  POSITIONING_DEMO_EXTERNAL_ORIGIN="$origin"
  save_config
  echo "Positioning demo external origin set."
}

do_set_keycloak_path_prefix() {
  local prefix="${1:-}"
  if [[ -z "$prefix" ]]; then
    if $HAS_GUM; then
      prefix="$(gum input --placeholder "/auth (empty for root path)")"
    else
      read -rp "Keycloak path prefix (/auth or empty): " prefix
    fi
  fi
  KEYCLOAK_PATH_PREFIX="$prefix"
  DASHBOARD_KEYCLOAK_PATH_PREFIX="$prefix"
  save_config
  echo "Keycloak path prefix set to: ${prefix:-<empty>}"
}

do_set_keycloak_external_url() {
  local url="${1:-}"
  if [[ -z "$url" ]]; then
    if $HAS_GUM; then
      url="$(gum input --placeholder "https://core.example.com")"
    else
      read -rp "Keycloak external URL (https://...): " url
    fi
  fi
  DASHBOARD_KEYCLOAK_EXTERNAL_URL="$url"
  save_config
  echo "Keycloak external URL set."
}

do_auth_network() {
  local action="${1:-}"
  local arg="${2:-}"
  if [[ -z "$action" ]]; then
    if ! $HAS_GUM; then
      echo "Usage: $0 auth-network status|mode|auth|origin|positioning-origin|prefix|keycloak-url|preset-cloudflare"
      return 1
    fi
    action="$(gum_choose \
      "Show status" \
      "Toggle dashboard dev frontend (true/false)" \
      "Set dashboard auth (enabled/disabled)" \
      "Set dashboard external origin" \
      "Set positioning demo external origin" \
      "Set keycloak path prefix" \
      "Set keycloak external URL" \
      "Apply cloudflare-style preset")"
  fi

  case "$action" in
    "Show status"|status)
      echo "DASHBOARD_DEV_ENABLED=${DASHBOARD_DEV_ENABLED}"
      echo "DASHBOARD_AUTH_ENABLED=${DASHBOARD_AUTH_ENABLED}"
      echo "KEYCLOAK_PATH_PREFIX=${KEYCLOAK_PATH_PREFIX}"
      echo "DASHBOARD_KEYCLOAK_EXTERNAL_URL=${DASHBOARD_KEYCLOAK_EXTERNAL_URL}"
      echo "DASHBOARD_KEYCLOAK_PATH_PREFIX=${DASHBOARD_KEYCLOAK_PATH_PREFIX}"
      echo "DASHBOARD_EXTERNAL_ORIGIN=${DASHBOARD_EXTERNAL_ORIGIN}"
      echo "DASHBOARD_DEV_EXTERNAL_URL=${DASHBOARD_DEV_EXTERNAL_URL}"
      echo "POSITIONING_DEMO_EXTERNAL_ORIGIN=${POSITIONING_DEMO_EXTERNAL_ORIGIN}"
      ;;
    "Toggle dashboard dev frontend (true/false)"|dev)
      do_set_dashboard_dev_enabled
      ;;
    "Set dashboard auth (enabled/disabled)"|auth)
      do_set_dashboard_auth
      ;;
    "Set dashboard external origin"|origin)
      do_set_external_origin
      ;;
    "Set positioning demo external origin"|positioning-origin)
      do_set_positioning_origin
      ;;
    "Set keycloak path prefix"|prefix)
      do_set_keycloak_path_prefix
      ;;
    "Set keycloak external URL"|keycloak-url)
      do_set_keycloak_external_url
      ;;
    "Apply cloudflare-style preset"|preset-cloudflare)
      local domain="$arg"
      if [[ -z "$domain" ]]; then
        if $HAS_GUM; then
          domain="$(gum input --placeholder "core.example.com")"
        else
          read -rp "Public domain (without scheme): " domain
        fi
      fi
      if [[ -z "$domain" ]]; then
        echo "Domain required."
        return 1
      fi
      DASHBOARD_AUTH_ENABLED="true"
      KEYCLOAK_PATH_PREFIX="/auth"
      DASHBOARD_KEYCLOAK_PATH_PREFIX="/auth"
      DASHBOARD_KEYCLOAK_EXTERNAL_URL="https://${domain}"
      DASHBOARD_EXTERNAL_ORIGIN="https://${domain}"
      DASHBOARD_DEV_EXTERNAL_URL="https://dev.${domain}"
      POSITIONING_DEMO_EXTERNAL_ORIGIN="https://${domain}"
      save_config
      echo "Applied preset for https://${domain}"
      ;;
    *)
      echo "Usage: $0 auth-network status|dev|auth|origin|positioning-origin|prefix|keycloak-url|preset-cloudflare"
      return 1
      ;;
  esac
}

do_iam_admin_password() {
  local password="${1:-}"
  if [[ "$password" == "--clear" ]]; then
    password=""
  elif [[ -z "$password" ]]; then
    if $HAS_GUM; then
      local action
      action="$(gum choose \
        "Auto-generate strong password" \
        "Enter password manually" \
        "Clear password")"
      case "$action" in
        "Auto-generate strong password")
          password="$(generate_password)"
          ;;
        "Enter password manually")
          password="$(gum input --password --placeholder "Keycloak admin password")"
          ;;
        "Clear password")
          password=""
          ;;
      esac
    else
      read -rsp "Keycloak admin password: " password
      echo ""
    fi
  fi
  KEYCLOAK_ADMIN_PASSWORD="$password"
  save_config
  save_secrets
  if [[ -n "$KEYCLOAK_ADMIN_PASSWORD" ]]; then
    echo "IAM admin password configured."
  else
    echo "IAM admin password cleared."
  fi
}

do_up() {
  echo "Starting testbed with profile: ${TESTBED_PROFILE}, edge: ${EDGE_ENABLED}"
  if ! gum_confirm "Proceed with vagrant up?"; then
    echo "Cancelled."
    return 0
  fi
  (
    export TESTBED_PROFILE EDGE_ENABLED DEPLOY_MODE PHYSICAL_RAN_ENABLED PHYSICAL_RAN_BRIDGE DASHBOARD_DEV_ENABLED DASHBOARD_AUTH_ENABLED KEYCLOAK_PATH_PREFIX DASHBOARD_KEYCLOAK_EXTERNAL_URL DASHBOARD_KEYCLOAK_PATH_PREFIX DASHBOARD_EXTERNAL_ORIGIN DASHBOARD_DEV_EXTERNAL_URL POSITIONING_DEMO_EXTERNAL_ORIGIN KEYCLOAK_ADMIN_PASSWORD CAMARA_CLIENT_SECRET DASHBOARD_READONLY_SECRET
    cd "$SCRIPT_DIR"
    vagrant up
  )
}

do_provision() {
  echo "Provisioning with: deploy=${DEPLOY_MODE}, edge=${EDGE_ENABLED}, ran=${PHYSICAL_RAN_ENABLED}"
  if ! gum_confirm "Run vagrant provision ansible?"; then
    echo "Cancelled."
    return 0
  fi
  ensure_required_secrets_for_provision || return 1
  (
    export TESTBED_PROFILE EDGE_ENABLED DEPLOY_MODE PHYSICAL_RAN_ENABLED PHYSICAL_RAN_BRIDGE DASHBOARD_DEV_ENABLED DASHBOARD_AUTH_ENABLED KEYCLOAK_PATH_PREFIX DASHBOARD_KEYCLOAK_EXTERNAL_URL DASHBOARD_KEYCLOAK_PATH_PREFIX DASHBOARD_EXTERNAL_ORIGIN DASHBOARD_DEV_EXTERNAL_URL POSITIONING_DEMO_EXTERNAL_ORIGIN KEYCLOAK_ADMIN_PASSWORD CAMARA_CLIENT_SECRET DASHBOARD_READONLY_SECRET
    cd "$SCRIPT_DIR"
    if worker_needs_ran_reload; then
      echo "Applying PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE} to worker via vagrant reload..."
      vagrant reload worker
    fi
    vagrant provision ansible --provision-with playbook
  )
}

do_run_phase() {
  local phase="${1:-}"
  local playbook_rel

  if [[ -z "$phase" ]]; then
    if ! $HAS_GUM; then
      echo "Usage: $0 run-phase <phase-dir>"
      return 1
    fi
    local options=()
    local pb
    for pb in "${SCRIPT_DIR}"/ansible/phases/[0-9][0-9]-*/playbook.yml; do
      [[ -f "$pb" ]] || continue
      options+=("$(basename "$(dirname "$pb")")")
    done
    if [[ ${#options[@]} -eq 0 ]]; then
      echo "No phase playbooks found under ansible/phases."
      return 1
    fi
    phase="$(gum_choose "${options[@]}")"
  fi

  if [[ ! -f "${SCRIPT_DIR}/ansible/phases/${phase}/playbook.yml" ]]; then
    echo "Unknown phase or missing playbook: ${phase}"
    return 1
  fi

  playbook_rel="phases/${phase}/playbook.yml"
  echo "Running single phase: ${playbook_rel}"

  (
    cd "$SCRIPT_DIR"
    vagrant ssh ansible -c "bash -lc 'set -euo pipefail; cd ~/ansible-ro; set -a; [ -f /vagrant/.testbed.env ] && source /vagrant/.testbed.env; [ -f /vagrant/.testbed.secrets ] && source /vagrant/.testbed.secrets; set +a; ansible-playbook ${playbook_rel} -e dashboard_dev_enabled=${DASHBOARD_DEV_ENABLED}'"
  )
}

# ─── Tests ─────────────────────────────────────────────────────────────
do_tests() {
  local tests_dir="${SCRIPT_DIR}/tests"
  if [[ ! -f "${tests_dir}/run_tests.py" ]]; then
    echo "Test suite not found at ${tests_dir}."
    return 1
  fi

  # Suites can be passed as args (non-interactive): ./testbed-config tests iam e2e
  local suites="$*"
  local verbose=""
  if [[ -z "$suites" ]]; then
    if $HAS_GUM; then
      suites="$(gum choose --no-limit \
        --header 'Select test suites (space to pick, enter to run; none = all enabled)' \
        iam e2e protocols ran performance resilience || true)"
    else
      echo "Available suites: iam e2e protocols ran performance resilience"
      read -rp "Suites (space-separated, empty = all enabled): " suites
    fi
    if gum_confirm "Verbose output?"; then
      verbose="-v"
    fi
  fi

  # The runner needs the cluster up and a netshoot pod in the 5g namespace for
  # reachability checks; iam reads secrets from .testbed.secrets. Test failures
  # must not kill the menu, so the runner exit code is swallowed here.
  (
    cd "$tests_dir"
    if [[ -z "${suites// /}" ]]; then
      python3 run_tests.py ${verbose} || true
    else
      for s in $suites; do
        echo "── Running suite: ${s} ──"
        python3 run_tests.py -s "$s" ${verbose} || true
      done
    fi
  )
}

# ─── Interactive mode ──────────────────────────────────────────────────
interactive_menu() {
  while true; do
    show_status
    local choice
    # Build menu: deploy mode toggle only visible when edge is enabled
    local menu_items=(
      "Set deployment profile"
      "Toggle edge VM"
      "Configure physical RAN"
      "Configure auth/network"
      "Set IAM admin password"
      "Manage IAM/CAMARA secrets"
      "Run single phase playbook"
      "Run tests"
    )
    if [[ "$EDGE_ENABLED" == "true" ]]; then
      menu_items+=("Toggle UERANSIM (deploy mode)")
    fi
    menu_items+=(
      "Start cluster (vagrant up)"
      "Run provisioning"
      "Show full status"
      "Exit"
    )
    choice="$(gum_choose "${menu_items[@]}")"
    case "$choice" in
      "Set deployment profile")          do_set_profile ;;
      "Toggle edge VM")                  do_edge ;;
      "Configure physical RAN")          do_ran ;;
      "Configure auth/network")          do_auth_network ;;
      "Set IAM admin password")          do_iam_admin_password ;;
      "Manage IAM/CAMARA secrets")       do_secrets ;;
      "Run single phase playbook")       do_run_phase ;;
      "Run tests")                       do_tests ;;
      "Toggle UERANSIM (deploy mode)")
        if [[ "$DEPLOY_MODE" == "full" ]]; then
          DEPLOY_MODE="core_only"
          echo "UERANSIM disabled (core_only)"
        else
          DEPLOY_MODE="full"
          echo "UERANSIM enabled (full)"
        fi
        save_config
        ;;
      "Start cluster (vagrant up)")      do_up ;;
      "Run provisioning")                do_provision ;;
      "Show full status")                show_status ;;
      "Exit"|"")                         break ;;
    esac
    echo ""
  done
}

# ─── CLI mode ──────────────────────────────────────────────────────────
check_gum() {
  if ! $HAS_GUM; then
    echo "gum is not installed. Install it for the best experience:"
    echo "  sudo mkdir -p /etc/apt/keyrings"
    echo '  curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg'
    echo '  echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list'
    echo "  sudo apt update && sudo apt install gum"
    echo ""
    echo "Falling back to basic terminal mode."
    echo ""
  fi
}

main() {
  load_config

  case "${1:-}" in
    show)
      show_status ;;
    set-profile)
      do_set_profile "${2:-}" ;;
    edge)
      do_edge "${2:-}" ;;
    ran)
      do_ran "${2:-}" ;;
    iam-admin-password)
      do_iam_admin_password "${2:-}" ;;
    secrets)
      do_secrets "${2:-}" ;;
    auth-network)
      do_auth_network "${2:-}" "${3:-}" ;;
    dashboard-dev)
      do_set_dashboard_dev_enabled "${2:-}" ;;
    dashboard-auth)
      do_set_dashboard_auth "${2:-}" ;;
    run-phase)
      do_run_phase "${2:-}" ;;
    tests)
      shift
      do_tests "$@" ;;
    up)
      do_up ;;
    provision)
      do_provision ;;
    env)
      # Print export commands for shell eval
      echo "export TESTBED_PROFILE=${TESTBED_PROFILE}"
      echo "export EDGE_ENABLED=${EDGE_ENABLED}"
      echo "export DEPLOY_MODE=${DEPLOY_MODE}"
      echo "export PHYSICAL_RAN_ENABLED=${PHYSICAL_RAN_ENABLED}"
      echo "export PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE}"
      echo "export DASHBOARD_DEV_ENABLED=${DASHBOARD_DEV_ENABLED}"
      echo "export DASHBOARD_AUTH_ENABLED=${DASHBOARD_AUTH_ENABLED}"
      echo "export KEYCLOAK_PATH_PREFIX=${KEYCLOAK_PATH_PREFIX}"
      echo "export DASHBOARD_KEYCLOAK_EXTERNAL_URL=${DASHBOARD_KEYCLOAK_EXTERNAL_URL}"
      echo "export DASHBOARD_KEYCLOAK_PATH_PREFIX=${DASHBOARD_KEYCLOAK_PATH_PREFIX}"
      echo "export DASHBOARD_EXTERNAL_ORIGIN=${DASHBOARD_EXTERNAL_ORIGIN}"
      echo "export DASHBOARD_DEV_EXTERNAL_URL=${DASHBOARD_DEV_EXTERNAL_URL}"
      echo "export POSITIONING_DEMO_EXTERNAL_ORIGIN=${POSITIONING_DEMO_EXTERNAL_ORIGIN}"
      echo "# Secrets are stored in .testbed.secrets:"
      echo "#   KEYCLOAK_ADMIN_PASSWORD"
      echo "#   CAMARA_CLIENT_SECRET"
      echo "#   DASHBOARD_READONLY_SECRET"
      ;;
    help|--help|-h)
      echo "Usage: $0 [command] [args]"
      echo ""
      echo "Interactive mode (no arguments):"
      echo "  $0                        Launch interactive TUI menu"
      echo ""
      echo "Commands:"
      echo "  show                      Show current configuration"
      echo "  set-profile <laptop|server>  Set deployment profile"
      echo "  edge <on|off>             Enable/disable edge VM"
      echo "  ran <nic|disable>         Configure physical RAN bridge"
      echo "  auth-network [status|dev|auth|origin|positioning-origin|prefix|keycloak-url|preset-cloudflare]"
      echo "                            Configure auth/domain/path values (gum-guided by default)"
      echo "  dashboard-dev [true|false]   Toggle the opt-in Vite dev frontend on the ansible VM"
      echo "  dashboard-auth [enabled|disabled] Set dashboard auth"
      echo "  iam-admin-password [pwd|--clear]  Set or clear Keycloak admin bootstrap password"
      echo "  secrets [generate-missing|manual|rotate|status|clear]  Manage IAM/CAMARA secrets"
      echo "  run-phase [phase-dir]     Run one ansible phase playbook with env auto-load"
      echo "  tests [suite...]          Run test suites (interactive picker if no args)"
      echo "  up                        Run vagrant up with current config"
      echo "  provision                 Run vagrant provision ansible (full playbook)"
      echo "  env                       Print export commands for current config"
      echo "  help                      Show this help"
      ;;
    "")
      check_gum
      interactive_menu ;;
    *)
      echo "Unknown command: $1 (try: $0 help)"
      exit 1 ;;
  esac
}

main "$@"
