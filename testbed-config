#!/usr/bin/env bash
# testbed-config — Interactive configuration tool for the 5G K3s KubeEdge Testbed
# Uses gum (https://github.com/charmbracelet/gum) for TUI when available.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.testbed.env"
APPLIED_RAN_FILE="${SCRIPT_DIR}/.physical_ran_bridge_applied"

# ─── Defaults ──────────────────────────────────────────────────────────
DEFAULT_PROFILE="laptop"
DEFAULT_EDGE="true"
DEFAULT_DEPLOY_MODE="core_only"
DEFAULT_PHYSICAL_RAN="false"
DEFAULT_DASHBOARD_MODE="prod"

# ─── Load persisted config ─────────────────────────────────────────────
load_config() {
  TESTBED_PROFILE="${DEFAULT_PROFILE}"
  EDGE_ENABLED="${DEFAULT_EDGE}"
  DEPLOY_MODE="${DEFAULT_DEPLOY_MODE}"
  PHYSICAL_RAN_ENABLED="${DEFAULT_PHYSICAL_RAN}"
  PHYSICAL_RAN_BRIDGE=""
  DASHBOARD_MODE="${DEFAULT_DASHBOARD_MODE}"

  if [[ -f "$ENV_FILE" ]]; then
    while IFS='=' read -r key value; do
      [[ -z "$key" || "$key" == \#* ]] && continue
      case "$key" in
        TESTBED_PROFILE)      TESTBED_PROFILE="$value" ;;
        EDGE_ENABLED)         EDGE_ENABLED="$value" ;;
        DEPLOY_MODE)          DEPLOY_MODE="$value" ;;
        PHYSICAL_RAN_ENABLED) PHYSICAL_RAN_ENABLED="$value" ;;
        PHYSICAL_RAN_BRIDGE)  PHYSICAL_RAN_BRIDGE="$value" ;;
        DASHBOARD_MODE)       DASHBOARD_MODE="$value" ;;
      esac
    done < "$ENV_FILE"
  fi
}

save_config() {
  cat > "$ENV_FILE" << EOF
# Generated by testbed-config — do not edit manually
TESTBED_PROFILE=${TESTBED_PROFILE}
EDGE_ENABLED=${EDGE_ENABLED}
DEPLOY_MODE=${DEPLOY_MODE}
PHYSICAL_RAN_ENABLED=${PHYSICAL_RAN_ENABLED}
PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE}
DASHBOARD_MODE=${DASHBOARD_MODE}
EOF
  echo "Configuration saved to .testbed.env"
}

read_applied_ran_bridge() {
  if [[ -f "$APPLIED_RAN_FILE" ]]; then
    tr -d '\n' < "$APPLIED_RAN_FILE"
  fi
}

worker_needs_ran_reload() {
  [[ "$PHYSICAL_RAN_ENABLED" == "true" ]] || return 1
  [[ -n "${PHYSICAL_RAN_BRIDGE}" ]] || return 1

  local applied
  applied="$(read_applied_ran_bridge)"
  [[ "$applied" != "$PHYSICAL_RAN_BRIDGE" ]]
}

# ─── Hardware detection ────────────────────────────────────────────────
detect_hardware() {
  local cpu_threads mem_gb
  cpu_threads="$(nproc 2>/dev/null || echo '?')"
  if command -v free &>/dev/null; then
    mem_gb="$(free -g | awk '/^Mem:/{print $2}')"
  else
    mem_gb="?"
  fi
  echo "${cpu_threads} threads, ${mem_gb} GB RAM"
}

suggest_profile() {
  local threads
  threads="$(nproc 2>/dev/null || echo 0)"
  if (( threads <= 8 )); then
    echo "server"
  else
    echo "laptop"
  fi
}

# ─── gum helpers ───────────────────────────────────────────────────────
HAS_GUM=false
command -v gum &>/dev/null && HAS_GUM=true

gum_or_echo() {
  if $HAS_GUM; then
    gum style --border rounded --padding "1 2" --border-foreground 39 "$@"
  else
    echo "═══════════════════════════════════════"
    printf '%s\n' "$@"
    echo "═══════════════════════════════════════"
  fi
}

gum_choose() {
  if $HAS_GUM; then
    gum choose "$@"
  else
    select choice in "$@"; do
      echo "$choice"
      return
    done
  fi
}

gum_confirm() {
  if $HAS_GUM; then
    gum confirm "$@"
  else
    read -rp "$* [y/N] " answer
    [[ "$answer" =~ ^[Yy] ]]
  fi
}

# ─── Display ───────────────────────────────────────────────────────────
show_status() {
  local hw
  hw="$(detect_hardware)"
  local edge_label
  [[ "$EDGE_ENABLED" == "true" ]] && edge_label="enabled" || edge_label="disabled"
  local ran_label
  [[ "$PHYSICAL_RAN_ENABLED" == "true" ]] && ran_label="${PHYSICAL_RAN_BRIDGE:-auto}" || ran_label="disabled"

  local ueransim_label
  if [[ "$EDGE_ENABLED" == "true" ]]; then
    [[ "$DEPLOY_MODE" == "full" ]] && ueransim_label="enabled" || ueransim_label="disabled"
  else
    ueransim_label="—  (requires edge)"
  fi

  if $HAS_GUM; then
    gum style --border rounded --padding "1 2" --border-foreground 39 \
      "5G K3s KubeEdge Testbed" \
      "────────────────────────" \
      "Hardware:  ${hw}" \
      "Profile:   ${TESTBED_PROFILE}" \
      "Edge VM:   ${edge_label}" \
      "UERANSIM:  ${ueransim_label}" \
      "RAN:       ${ran_label}" \
      "Dashboard: ${DASHBOARD_MODE}"
  else
    echo ""
    echo "  5G K3s KubeEdge Testbed"
    echo "  ────────────────────────"
    echo "  Hardware:  ${hw}"
    echo "  Profile:   ${TESTBED_PROFILE}"
    echo "  Edge VM:   ${edge_label}"
    echo "  UERANSIM:  ${ueransim_label}"
    echo "  RAN:       ${ran_label}"
    echo "  Dashboard: ${DASHBOARD_MODE}"
    echo ""
  fi
}

# ─── Actions ───────────────────────────────────────────────────────────
do_set_profile() {
  local profile="${1:-}"
  if [[ -z "$profile" ]]; then
    echo ""
    echo "  laptop  — 4 VMs (18 vCPU, 17 GB) with edge (current default)"
    echo "  server  — 3 VMs (7 vCPU, 14 GB) no edge, optimized for NUC/server"
    echo ""
    profile="$(gum_choose "laptop" "server")"
  fi
  case "$profile" in
    laptop|server) TESTBED_PROFILE="$profile" ;;
    *) echo "Unknown profile: $profile (valid: laptop, server)"; return 1 ;;
  esac
  # Adjust edge and deploy mode per profile
  if [[ "$TESTBED_PROFILE" == "server" ]]; then
    EDGE_ENABLED="false"
    DEPLOY_MODE="core_only"
  else
    EDGE_ENABLED="true"
  fi
  save_config
  echo "Profile set to: ${TESTBED_PROFILE} (edge: ${EDGE_ENABLED}, deploy: ${DEPLOY_MODE})"
}

do_edge() {
  local toggle="${1:-}"
  if [[ -z "$toggle" ]]; then
    if gum_confirm "Enable edge VM?"; then
      toggle="on"
    else
      toggle="off"
    fi
  fi
  case "$toggle" in
    on|true)
      EDGE_ENABLED="true"
      # Ask whether to also deploy UERANSIM on the edge
      if [[ "$DEPLOY_MODE" != "full" ]]; then
        if gum_confirm "Also deploy UERANSIM on edge? (full mode)"; then
          DEPLOY_MODE="full"
        fi
      fi
      ;;
    off|false)
      EDGE_ENABLED="false"
      DEPLOY_MODE="core_only"
      ;;
    *) echo "Usage: $0 edge on|off"; return 1 ;;
  esac
  save_config
  echo "Edge VM: ${EDGE_ENABLED} (deploy: ${DEPLOY_MODE})"
}

do_ran() {
  local nic="${1:-}"
  if [[ -z "$nic" ]]; then
    echo ""
    echo "Available network interfaces:"
    local nics
    nics="$(ip -o link show | awk -F': ' '{print $2}' | grep -v '^lo$')"
    echo "$nics"
    echo ""
    nic="$(echo "$nics" | gum_choose)"
  fi
  if [[ -z "$nic" || "$nic" == "disable" ]]; then
    PHYSICAL_RAN_ENABLED="false"
    PHYSICAL_RAN_BRIDGE=""
  else
    PHYSICAL_RAN_ENABLED="true"
    PHYSICAL_RAN_BRIDGE="$nic"
  fi
  save_config
  echo "Physical RAN: ${PHYSICAL_RAN_ENABLED} (bridge: ${PHYSICAL_RAN_BRIDGE:-none})"
}

do_up() {
  echo "Starting testbed with profile: ${TESTBED_PROFILE}, edge: ${EDGE_ENABLED}"
  if ! gum_confirm "Proceed with vagrant up?"; then
    echo "Cancelled."
    return 0
  fi
  (
    export TESTBED_PROFILE EDGE_ENABLED DEPLOY_MODE PHYSICAL_RAN_ENABLED PHYSICAL_RAN_BRIDGE DASHBOARD_MODE
    cd "$SCRIPT_DIR"
    vagrant up
  )
}

do_provision() {
  echo "Provisioning with: deploy=${DEPLOY_MODE}, edge=${EDGE_ENABLED}, ran=${PHYSICAL_RAN_ENABLED}"
  if ! gum_confirm "Run vagrant provision ansible?"; then
    echo "Cancelled."
    return 0
  fi
  (
    export TESTBED_PROFILE EDGE_ENABLED DEPLOY_MODE PHYSICAL_RAN_ENABLED PHYSICAL_RAN_BRIDGE DASHBOARD_MODE
    cd "$SCRIPT_DIR"
    if worker_needs_ran_reload; then
      echo "Applying PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE} to worker via vagrant reload..."
      vagrant reload worker
    fi
    vagrant provision ansible --provision-with playbook
  )
}

# ─── Interactive mode ──────────────────────────────────────────────────
interactive_menu() {
  while true; do
    show_status
    local choice
    # Build menu: deploy mode toggle only visible when edge is enabled
    local menu_items=(
      "Set deployment profile"
      "Toggle edge VM"
      "Configure physical RAN"
    )
    if [[ "$EDGE_ENABLED" == "true" ]]; then
      menu_items+=("Toggle UERANSIM (deploy mode)")
    fi
    menu_items+=(
      "Start cluster (vagrant up)"
      "Run provisioning"
      "Show full status"
      "Exit"
    )
    choice="$(gum_choose "${menu_items[@]}")"
    case "$choice" in
      "Set deployment profile")          do_set_profile ;;
      "Toggle edge VM")                  do_edge ;;
      "Configure physical RAN")          do_ran ;;
      "Toggle UERANSIM (deploy mode)")
        if [[ "$DEPLOY_MODE" == "full" ]]; then
          DEPLOY_MODE="core_only"
          echo "UERANSIM disabled (core_only)"
        else
          DEPLOY_MODE="full"
          echo "UERANSIM enabled (full)"
        fi
        save_config
        ;;
      "Start cluster (vagrant up)")      do_up ;;
      "Run provisioning")                do_provision ;;
      "Show full status")                show_status ;;
      "Exit"|"")                         break ;;
    esac
    echo ""
  done
}

# ─── CLI mode ──────────────────────────────────────────────────────────
check_gum() {
  if ! $HAS_GUM; then
    echo "gum is not installed. Install it for the best experience:"
    echo "  sudo mkdir -p /etc/apt/keyrings"
    echo '  curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg'
    echo '  echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list'
    echo "  sudo apt update && sudo apt install gum"
    echo ""
    echo "Falling back to basic terminal mode."
    echo ""
  fi
}

main() {
  load_config

  case "${1:-}" in
    show)
      show_status ;;
    set-profile)
      do_set_profile "${2:-}" ;;
    edge)
      do_edge "${2:-}" ;;
    ran)
      do_ran "${2:-}" ;;
    up)
      do_up ;;
    provision)
      do_provision ;;
    env)
      # Print export commands for shell eval
      echo "export TESTBED_PROFILE=${TESTBED_PROFILE}"
      echo "export EDGE_ENABLED=${EDGE_ENABLED}"
      echo "export DEPLOY_MODE=${DEPLOY_MODE}"
      echo "export PHYSICAL_RAN_ENABLED=${PHYSICAL_RAN_ENABLED}"
      echo "export PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE}"
      echo "export DASHBOARD_MODE=${DASHBOARD_MODE}"
      ;;
    help|--help|-h)
      echo "Usage: $0 [command] [args]"
      echo ""
      echo "Interactive mode (no arguments):"
      echo "  $0                        Launch interactive TUI menu"
      echo ""
      echo "Commands:"
      echo "  show                      Show current configuration"
      echo "  set-profile <laptop|server>  Set deployment profile"
      echo "  edge <on|off>             Enable/disable edge VM"
      echo "  ran <nic|disable>         Configure physical RAN bridge"
      echo "  up                        Run vagrant up with current config"
      echo "  provision                 Run vagrant provision ansible (full playbook)"
      echo "  env                       Print export commands for current config"
      echo "  help                      Show this help"
      ;;
    "")
      check_gum
      interactive_menu ;;
    *)
      echo "Unknown command: $1 (try: $0 help)"
      exit 1 ;;
  esac
}

main "$@"
