phase_tags() {
  # Tags a phase playbook declares, both YAML forms: inline "tags: [a, b]" and a
  # block list under "tags:". The phaseN tags are dropped: they select the whole
  # phase, which is what running without a tag already does.
  local playbook="$1"
  [[ -f "$playbook" ]] || return 0
  awk '
    /^[[:space:]]*tags:[[:space:]]*\[/ {
      line = $0
      sub(/^[^[]*\[/, "", line); sub(/\].*$/, "", line)
      n = split(line, parts, ",")
      for (i = 1; i <= n; i++) { gsub(/[[:space:]"'"'"']/, "", parts[i]); if (parts[i] != "") print parts[i] }
      next
    }
    /^[[:space:]]*tags:[[:space:]]*$/ { inblock = 1; next }
    inblock && /^[[:space:]]*-[[:space:]]/ {
      item = $0
      sub(/^[[:space:]]*-[[:space:]]*/, "", item); gsub(/[[:space:]"'"'"']/, "", item)
      if (item != "") print item
      next
    }
    { inblock = 0 }
  ' "$playbook" | grep -Ev '^phase[0-9]*$' | sort -u
}

do_run_phase() {
  local phase="${1:-}"
  local playbook_rel
  # Naming the phase on the command line means "run this phase", so no prompt may
  # follow: a subcommand invocation has to be non-interactive end to end for
  # scripts and agents. Prompts belong to the menu path, where no phase was named.
  # See QUICKSTART.md "Two interfaces, one behavior".
  local interactive_entry=false
  [[ -z "$phase" ]] && interactive_entry=true
  shift || true

  # Remaining positional args, in the flagless grammar: a comma list selects
  # tags, anything shaped key=value becomes an extra var. Without these the only
  # way to run a subset of a phase was a hand-written ansible-playbook, which
  # skips the persisted config and secrets.
  # See QUICKSTART.md "Two interfaces, one behavior".
  local tags="" extra_vars=""
  local arg
  for arg in "$@"; do
    [[ -z "$arg" ]] && continue
    if [[ "$arg" == *=* ]]; then
      extra_vars+=" -e ${arg}"
    else
      tags="${tags:+${tags},}${arg}"
    fi
  done

  if [[ -z "$phase" ]]; then
    if ! $HAS_GUM; then
      echo "Usage: $0 run-phase <phase-dir>"
      return 1
    fi
    local options=()
    local pb
    for pb in "${SCRIPT_DIR}"/ansible/phases/[0-9][0-9]-*/playbook.yml; do
      [[ -f "$pb" ]] || continue
      options+=("$(basename "$(dirname "$pb")")")
    done
    if [[ ${#options[@]} -eq 0 ]]; then
      echo "No phase playbooks found under ansible/phases."
      return 1
    fi
    phase="$(gum_choose_or_cancel "${options[@]}")"
    [[ -z "$phase" ]] && { echo "Cancelled."; return 0; }
  fi

  if [[ ! -f "${SCRIPT_DIR}/ansible/phases/${phase}/playbook.yml" ]]; then
    echo "Unknown phase or missing playbook: ${phase}"
    return 1
  fi

  playbook_rel="phases/${phase}/playbook.yml"
  echo "Running single phase: ${playbook_rel}${tags:+ (tags: ${tags})}"

  # Offer the phase's tags when the operator picked interactively and named none.
  if $interactive_entry && $HAS_GUM && [[ -z "$tags" ]]; then
    local available
    available="$(phase_tags "${SCRIPT_DIR}/ansible/phases/${phase}/playbook.yml")"
    if [[ -n "$available" ]]; then
      local picked
      picked="$(gum_choose_or_cancel "Whole phase" $available)"
      [[ "$picked" != "Whole phase" && -n "$picked" ]] && tags="$picked"
    fi
  fi

  # Per-phase pre-prompts. Phase 08 has a guarded reconcile step the
  # operator must opt into each run (or persist the answer). The result
  # is passed to the playbook as KEYCLOAK_REALM_RECONCILE on this run
  # only; persisted defaults already live in .testbed.env.
  local phase_extra_env=""
  local phase_extra_args=""
  if [[ "$phase" == 08-iam* ]]; then
    prompt_kc_reconcile
    phase_extra_env="KEYCLOAK_REALM_RECONCILE=${KC_RECONCILE_THIS_RUN} "
  fi
  # Running UERANSIM standalone means you want it deployed, so enable it for this run.
  if [[ "$phase" == 06-ueransim-mec* ]]; then
    phase_extra_args="-e ueransim_enabled=true"
  fi
  phase_extra_args+="${extra_vars}${tags:+ --tags ${tags}}"

  (
    cd "$SCRIPT_DIR"
    vagrant ssh ansible -c "bash -lc 'set -euo pipefail; cd ~/ansible-ro; set -a; [ -f /vagrant/.testbed.env ] && source /vagrant/.testbed.env; [ -f /vagrant/.testbed.secrets ] && source /vagrant/.testbed.secrets; set +a; ${phase_extra_env}ansible-playbook ${playbook_rel} -e dashboard_dev_enabled=${DASHBOARD_DEV_ENABLED} ${phase_extra_args}'"
  )
}

# ─── Update ────────────────────────────────────────────────────────────
# KELT is distributed as a git clone, so updating the testbed is a pull of this
# repository. Container images are versioned separately: all.yml carries the
# committed baseline and the cluster carries what actually runs. A phase run
# keeps whichever is newer and reports the drift, so pulling a newer baseline is
# what clears that notice. Nothing here edits all.yml, which is upstream code and
# not operator configuration (that lives in .testbed.env).
# See docs/development/contributing.md "Component image versions".

git_repo_ready() {
  # True only when this checkout can actually be updated: a git repo whose
  # current branch tracks an upstream. A tarball copy silently skips updates.
  git -C "$SCRIPT_DIR" rev-parse --git-dir >/dev/null 2>&1 || return 1
  git -C "$SCRIPT_DIR" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1
}

update_commits_behind() {
  git -C "$SCRIPT_DIR" rev-list --count 'HEAD..@{u}' 2>/dev/null || true
}

# Commits available upstream, or empty. Set by check_for_updates, read by the
# menu banner and by `up`.
UPDATE_BEHIND=""

check_for_updates() {
  # Best effort and never fatal: no network, no remote, or a detached HEAD all
  # mean "no notice", never a blocked CLI. Fetches at most once a day so opening
  # the menu does not wait on the network every time.
  UPDATE_BEHIND=""
  git_repo_ready || return 0
  local git_dir fetch_head
  git_dir="$(git -C "$SCRIPT_DIR" rev-parse --git-dir)"
  fetch_head="${git_dir}/FETCH_HEAD"
  if [[ ! -f "$fetch_head" ]] || [[ -n "$(find "$fetch_head" -mtime +0 2>/dev/null)" ]]; then
    timeout 20 git -C "$SCRIPT_DIR" fetch --quiet 2>/dev/null || return 0
  fi
  local behind
  behind="$(update_commits_behind)"
  [[ -n "$behind" && "$behind" -gt 0 ]] && UPDATE_BEHIND="$behind"
  return 0
}

update_suggest_phases() {
  # Map the paths a pull touched onto the phases worth re-running, so the
  # operator is not left guessing which part of the deployment moved.
  local range="$1" changed phases
  changed="$(git -C "$SCRIPT_DIR" diff --name-only "$range" 2>/dev/null || true)"
  [[ -z "$changed" ]] && return 0

  phases="$(printf '%s\n' "$changed" \
    | sed -n 's|^ansible/phases/\([0-9][0-9]-[a-z0-9-]*\)/.*|\1|p' | sort -u)"
  # The dashboard sources are deployed by phase 09, not by a phase directory.
  if printf '%s\n' "$changed" | grep -q '^dashboard/'; then
    phases="$(printf '%s\n09-dashboard\n' "$phases" | sed '/^$/d' | sort -u)"
  fi

  if [[ -n "$phases" ]]; then
    echo ""
    echo "Phases touched by this update:"
    while read -r phase; do
      [[ -n "$phase" ]] && echo "  testbed run-phase ${phase}"
    done <<< "$phases"
  fi
  if printf '%s\n' "$changed" | grep -q '^ansible/group_vars/all.yml$'; then
    echo ""
    echo "all.yml changed (shared variables, including image baselines):"
    echo "  a full 'testbed provision' applies it everywhere."
  fi
  if printf '%s\n' "$changed" | grep -q '^Vagrantfile$'; then
    echo ""
    echo "The Vagrantfile changed: VM definitions only take effect on"
    echo "  vagrant reload  (or a fresh 'testbed up')."
  fi
}

do_update() {
  if ! git_repo_ready; then
    gum_or_echo "Cannot update automatically" \
      "This directory is not a git checkout with an upstream branch," \
      "so there is nothing to pull. Re-clone KELT to get updates."
    return 0
  fi

  echo "Checking for updates..."
  if ! timeout 30 git -C "$SCRIPT_DIR" fetch --quiet; then
    echo "Could not reach the remote. Nothing changed."
    return 0
  fi

  local behind
  behind="$(update_commits_behind)"
  if [[ -z "$behind" || "$behind" -eq 0 ]]; then
    gum_or_echo "KELT is up to date" "No new commits upstream."
    return 0
  fi

  echo ""
  echo "${behind} new commit(s) upstream:"
  git -C "$SCRIPT_DIR" log --oneline --no-decorate 'HEAD..@{u}' | head -20
  echo ""

  # A dirty tree is the normal state for whoever develops KELT, so this warns
  # and stops rather than stashing or discarding anything.
  if [[ -n "$(git -C "$SCRIPT_DIR" status --porcelain)" ]]; then
    gum_or_echo "Local changes present" \
      "This checkout has uncommitted changes, so the update stops here." \
      "Commit or stash them, then run 'testbed update' again."
    return 0
  fi

  if ! gum_confirm "Pull ${behind} commit(s) now?"; then
    echo "Cancelled."
    return 0
  fi

  local before
  before="$(git -C "$SCRIPT_DIR" rev-parse HEAD)"
  # --ff-only: an update must never produce a merge commit in an operator's
  # checkout. A diverged branch is a decision for whoever made it.
  if ! git -C "$SCRIPT_DIR" merge --ff-only '@{u}'; then
    gum_or_echo "Update stopped" \
      "This branch has diverged from upstream and cannot fast-forward." \
      "Resolve it with git, then run 'testbed update' again."
    return 0
  fi

  echo ""
  echo "Updated to $(git -C "$SCRIPT_DIR" rev-parse --short HEAD)."
  update_suggest_phases "${before}..HEAD"
}

# ─── Tests ─────────────────────────────────────────────────────────────
do_tests() {
  local tests_dir="${SCRIPT_DIR}/tests"
  if [[ ! -f "${tests_dir}/run_tests.py" ]]; then
    echo "Test suite not found at ${tests_dir}."
    return 1
  fi

  # Suites can be passed as args (non-interactive): ./testbed-config tests iam e2e
  local suites="$*"
  local verbose=""
  if [[ -z "$suites" ]]; then
    if $HAS_GUM; then
      suites="$(gum choose --no-limit \
        --header 'Select test suites (space to pick, enter to run; none = all enabled)' \
        iam e2e protocols ran performance resilience || true)"
    else
      echo "Available suites: iam e2e protocols ran performance resilience"
      read -rp "Suites (space-separated, empty = all enabled): " suites
    fi
    if gum_confirm "Verbose output?"; then
      verbose="-v"
    fi
  fi

  # The runner needs the cluster up and a netshoot pod in the 5g namespace for
  # reachability checks; iam reads secrets from .testbed.secrets. Test failures
  # must not kill the menu, so the runner exit code is swallowed here.
  (
    cd "$tests_dir"
    if [[ -z "${suites// /}" ]]; then
      python3 run_tests.py ${verbose} || true
    else
      for s in $suites; do
        echo "── Running suite: ${s} ──"
        python3 run_tests.py -s "$s" ${verbose} || true
      done
    fi
  )
}

