do_auth_network() {
  local action="${1:-}"
  local arg="${2:-}"
  if [[ -z "$action" ]]; then
    if ! $HAS_GUM; then
      echo "Usage: $0 auth-network status|dev|auth|base-domain|origin|positioning-origin|prefix|keycloak-url|preset-cloudflare"
      return 1
    fi
    action="$(gum_choose_or_cancel \
      "Show status" \
      "Toggle dashboard dev frontend (true/false)" \
      "Set dashboard auth (enabled/disabled)" \
      "Set external base domain" \
      "Apply cloudflare-style preset" \
      "Set dashboard external origin" \
      "Set positioning demo external origin" \
      "Set keycloak path prefix" \
      "Set keycloak external URL")"
    [[ -z "$action" ]] && { echo "Cancelled."; return 0; }
  fi

  case "$action" in
    "Show status"|status)
      echo "DASHBOARD_DEV_ENABLED=${DASHBOARD_DEV_ENABLED}"
      echo "DASHBOARD_AUTH_ENABLED=${DASHBOARD_AUTH_ENABLED}"
      echo "EXTERNAL_BASE_DOMAIN=${EXTERNAL_BASE_DOMAIN:-<unset, LAN NodePorts>}"
      echo "KEYCLOAK_PATH_PREFIX=${KEYCLOAK_PATH_PREFIX}"
      echo "DASHBOARD_KEYCLOAK_EXTERNAL_URL=${DASHBOARD_KEYCLOAK_EXTERNAL_URL}"
      echo "DASHBOARD_KEYCLOAK_PATH_PREFIX=${DASHBOARD_KEYCLOAK_PATH_PREFIX}"
      echo "DASHBOARD_EXTERNAL_ORIGIN=${DASHBOARD_EXTERNAL_ORIGIN}"
      echo "DASHBOARD_DEV_EXTERNAL_URL=${DASHBOARD_DEV_EXTERNAL_URL}"
      echo "CAMARA_GATEWAY_EXTERNAL_ORIGIN=${CAMARA_GATEWAY_EXTERNAL_ORIGIN}"
      echo "POSITIONING_DEMO_EXTERNAL_ORIGIN=${POSITIONING_DEMO_EXTERNAL_ORIGIN}"
      ;;
    "Toggle dashboard dev frontend (true/false)"|dev)
      do_set_dashboard_dev_enabled
      ;;
    "Set dashboard auth (enabled/disabled)"|auth)
      do_set_dashboard_auth
      ;;
    "Set dashboard external origin"|origin)
      do_set_external_origin
      ;;
    "Set positioning demo external origin"|positioning-origin)
      do_set_positioning_origin
      ;;
    "Set keycloak path prefix"|prefix)
      do_set_keycloak_path_prefix
      ;;
    "Set keycloak external URL"|keycloak-url)
      do_set_keycloak_external_url
      ;;
    "Set external base domain"|base-domain)
      do_set_base_domain "$arg"
      ;;
    "Apply cloudflare-style preset"|preset-cloudflare)
      # Single-base model: set one base domain and let ansible derive every
      # surface as <subdomain>.<base>. The phase 11 front-door routes them by
      # Host, so Cloudflare needs ONE wildcard tunnel (*.<base>) and one Access
      # app, not a route per service. See docs/security/external-access.md.
      local domain="$arg"
      if [[ -z "$domain" ]]; then
        if $HAS_GUM; then
          domain="$(gum input --placeholder "example.com (base domain; subdomains derived)")"
        else
          read -rp "Public base domain (subdomains derived): " domain
        fi
      fi
      if [[ -z "$domain" ]]; then
        echo "Domain required."
        return 1
      fi
      DASHBOARD_AUTH_ENABLED="true"
      EXTERNAL_BASE_DOMAIN="${domain}"
      # Clear per-service overrides so all surfaces derive from the base domain.
      # (Set one of these again only for a deliberate one-off override.)
      KEYCLOAK_PATH_PREFIX=""
      DASHBOARD_KEYCLOAK_PATH_PREFIX=""
      DASHBOARD_KEYCLOAK_EXTERNAL_URL=""
      DASHBOARD_EXTERNAL_ORIGIN=""
      DASHBOARD_DEV_EXTERNAL_URL=""
      CAMARA_GATEWAY_EXTERNAL_ORIGIN=""
      POSITIONING_DEMO_EXTERNAL_ORIGIN=""
      save_config
      echo "Applied single-base preset for ${domain}:"
      echo "  dashboard:   https://kelt.${domain}   (also /auth /api /docs)"
      echo "  CAMARA API:  https://api.${domain}"
      echo "  demo:        https://demo.${domain}"
      echo "  placement:   https://placement.${domain}"
      echo "  dev:         https://dev.${domain}   (when dashboard dev enabled)"
      echo ""
      echo "Cloudflare (one-time): point a wildcard tunnel *.${domain} -> worker:31500 (front-door NodePort),"
      echo "  add one Access app for *.${domain}, and Bypass /auth/realms/* (OIDC) and api.${domain} (M2M)."
      ;;
    *)
      echo "Usage: $0 auth-network status|dev|auth|base-domain|origin|positioning-origin|prefix|keycloak-url|preset-cloudflare"
      return 1
      ;;
  esac
}

do_iam_admin_password() {
  local password="${1:-}"
  if [[ "$password" == "--clear" ]]; then
    password=""
  elif [[ -z "$password" ]]; then
    if $HAS_GUM; then
      local action
      action="$(gum_choose_or_cancel \
        "Auto-generate strong password" \
        "Enter password manually" \
        "Clear password")"
      [[ -z "$action" ]] && { echo "Cancelled."; return 0; }
      case "$action" in
        "Auto-generate strong password")
          password="$(generate_password)"
          ;;
        "Enter password manually")
          password="$(gum input --password --placeholder "Keycloak admin password")"
          ;;
        "Clear password")
          password=""
          ;;
      esac
    else
      read -rsp "Keycloak admin password: " password
      echo ""
    fi
  fi
  KEYCLOAK_ADMIN_PASSWORD="$password"
  save_config
  save_secrets
  if [[ -n "$KEYCLOAK_ADMIN_PASSWORD" ]]; then
    echo "IAM admin password configured."
  else
    echo "IAM admin password cleared."
  fi
}

