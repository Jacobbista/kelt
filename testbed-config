menu_deploy() {
  while true; do
    local autostart
    autostart="$(autostart_status)"
    local items=(
      "Start cluster (vagrant up)"
      "Run provisioning (full playbook)"
      "Run single phase playbook"
      "Auto-start at boot: ${autostart}"
      "← Back"
    )
    local choice
    choice="$(gum_choose "${items[@]}")"
    case "$choice" in
      "Start cluster (vagrant up)")        do_up ;;
      "Run provisioning (full playbook)")  do_provision ;;
      "Run single phase playbook")         do_run_phase ;;
      "Auto-start at boot: ${autostart}")
        local act
        act="$(gum_choose "Enable" "Disable" "Cancel")"
        case "$act" in
          "Enable")  do_autostart on ;;
          "Disable") do_autostart off ;;
        esac
        ;;
      "← Back"|"")                          break ;;
    esac
    case "$choice" in
      "← Back"|"") ;;
      *)           prompt_continue ;;
    esac
  done
}

