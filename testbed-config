do_autostart() {
  local action="${1:-status}"
  case "$action" in
    on|enable)
      local vagrant_bin
      vagrant_bin="$(command -v vagrant || echo /usr/bin/vagrant)"
      echo "Installing systemd unit at $AUTOSTART_UNIT (sudo required)..."
      sudo tee "$AUTOSTART_UNIT" >/dev/null <<EOF
[Unit]
Description=5G K3s KubeEdge Testbed (vagrant up)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=${USER}
Group=${USER}
WorkingDirectory=${SCRIPT_DIR}
Environment=HOME=${HOME}
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=${vagrant_bin} up
ExecStop=${vagrant_bin} halt
RemainAfterExit=yes
TimeoutStartSec=30m
TimeoutStopSec=5m
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF
      sudo systemctl daemon-reload
      sudo systemctl enable 5g-testbed.service
      echo ""
      echo "Autostart enabled. Cluster will start on next boot."
      echo "Follow logs with: journalctl -u 5g-testbed.service -f"
      ;;
    off|disable)
      if [ -f "$AUTOSTART_UNIT" ]; then
        sudo systemctl disable 5g-testbed.service 2>/dev/null || true
        sudo rm -f "$AUTOSTART_UNIT"
        sudo systemctl daemon-reload
        echo "Autostart disabled and unit removed."
      else
        echo "Autostart already disabled (no unit present)."
      fi
      ;;
    status|"")
      echo "Autostart: $(autostart_status)"
      [ -f "$AUTOSTART_UNIT" ] && echo "Unit file:  $AUTOSTART_UNIT"
      ;;
    *)
      echo "Usage: testbed-config autostart [on|off|status]"
      return 1
      ;;
  esac
}

install_gum_apt() {
  local rc=0
  sudo mkdir -p /etc/apt/keyrings || return 1
  curl -fsSL https://repo.charm.sh/apt/gpg.key \
    | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg || return 1
  echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" \
    | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null
  sudo apt-get update -qq || rc=1
  sudo apt-get install -y gum || rc=1
  command -v gum >/dev/null && return 0 || return $rc
}

check_gum() {
  if $HAS_GUM; then return 0; fi
  if [[ -t 0 && -t 1 ]]; then
    echo "gum (TUI helper) is not installed. It powers the interactive menu."
    read -r -p "Install gum now via apt (uses sudo)? [Y/n] " reply
    reply="${reply:-Y}"
    if [[ "$reply" =~ ^[yY] ]]; then
      if install_gum_apt; then
        HAS_GUM=true
        echo "gum installed."
        echo ""
        return 0
      else
        echo "gum install failed. Continuing in basic terminal mode."
        echo ""
        return 1
      fi
    fi
  fi
  echo "Continuing without gum (basic terminal mode)."
  echo "Re-run 'testbed-config install' later to install gum + the 'testbed' alias."
  echo ""
}

do_install_cli() {
  local bin_path="$SCRIPT_DIR/testbed-config"
  local rc_file="${HOME}/.bashrc"
  local marker_alias="# TESTBED_CONFIG_ALIAS"
  local marker_comp="# TESTBED_CONFIG_COMPLETION"

  if ! $HAS_GUM; then
    read -r -p "Install gum via apt as well? [Y/n] " reply
    reply="${reply:-Y}"
    if [[ "$reply" =~ ^[yY] ]]; then
      install_gum_apt && HAS_GUM=true || echo "gum install failed (continuing with alias setup)."
    fi
  fi

  if grep -q "$marker_alias" "$rc_file" 2>/dev/null; then
    echo "Alias already present in $rc_file"
  else
    {
      echo ""
      echo "$marker_alias"
      echo "alias testbed='$bin_path'"
    } >> "$rc_file"
    echo "Added alias 'testbed' -> $bin_path in $rc_file"
  fi

  local comp_dir="${HOME}/.bash_completion.d"
  mkdir -p "$comp_dir"
  local comp_file="$comp_dir/testbed"
  cat > "$comp_file" <<'BASH'
_testbed_complete() {
  local cur prev opts
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  opts="show endpoints set-profile edge ran northbound dev-hooks auth-network dashboard-dev dashboard-auth \
iam iam-admin-password secrets run-phase tests up provision env install onboarding \
autostart help"
  case "$prev" in
    set-profile)        COMPREPLY=( $(compgen -W "laptop server" -- "$cur") ); return ;;
    run-phase)          COMPREPLY=( $(compgen -W "$(ls -d ansible/phases/[0-9][0-9]-*/ 2>/dev/null | xargs -n1 basename 2>/dev/null)" -- "$cur") ); return ;;
    edge|dashboard-dev|northbound) COMPREPLY=( $(compgen -W "true false on off" -- "$cur") ); return ;;
    dev-hooks)          COMPREPLY=( $(compgen -W "on off status release" -- "$cur") ); return ;;
    dashboard-auth)     COMPREPLY=( $(compgen -W "enabled disabled" -- "$cur") ); return ;;
    auth-network)       COMPREPLY=( $(compgen -W "status dev auth origin positioning-origin prefix keycloak-url preset-cloudflare" -- "$cur") ); return ;;
    iam)                COMPREPLY=( $(compgen -W "reconcile" -- "$cur") ); return ;;
    reconcile)          COMPREPLY=( $(compgen -W "on off ask status" -- "$cur") ); return ;;
    secrets)            COMPREPLY=( $(compgen -W "generate-missing manual rotate status clear" -- "$cur") ); return ;;
    autostart)          COMPREPLY=( $(compgen -W "on off status" -- "$cur") ); return ;;
  esac
  COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
}
complete -F _testbed_complete testbed
complete -F _testbed_complete testbed-config
BASH
  echo "Wrote bash completion -> $comp_file"

  if ! grep -q "$marker_comp" "$rc_file" 2>/dev/null; then
    {
      echo ""
      echo "$marker_comp"
      echo "[ -f $comp_file ] && source $comp_file"
    } >> "$rc_file"
    echo "Registered completion source in $rc_file"
  fi

  echo ""
  echo "Done. The alias is live in any NEW shell you open."
  echo "To use it in THIS shell right now, run one of:"
  echo "    source $rc_file"
  echo "    exec bash"
  echo "Then call:  testbed help"
}

# ─── Developer git hooks (opt-in, developer-only) ───────────────────────────
# Local pre-commit (gitleaks, blocks) + pre-push (advisory: reminds to tag the
# frontend, flags WIP). The actual release/tag is a confirmed command below.
# See docs/development/contributing.md.
_devhooks_fe_version() {
  python3 -c "import json;print(json.load(open('${SCRIPT_DIR}/dashboard/frontend/package.json'))['version'])" 2>/dev/null
}
_devhooks_fe_last_tag() {
  git -C "$SCRIPT_DIR" tag --list 'dashboard-frontend-v*' --sort=-v:refname 2>/dev/null | head -1
}
_devhooks_fe_changed_since() {  # $1=tag ; 0 (true) if frontend changed since it
  local tag="$1"
  [ -z "$tag" ] && return 0
  ! git -C "$SCRIPT_DIR" diff --quiet "$tag" HEAD -- dashboard/frontend 2>/dev/null
}
_devhooks_bump() {  # $1=x.y.z  $2=patch|minor|major  -> new version
  python3 - "$1" "$2" <<'PY'
import sys
x, y, z = (int(n) for n in sys.argv[1].split("."))
part = sys.argv[2]
if part == "major": x, y, z = x + 1, 0, 0
elif part == "minor": y, z = y + 1, 0
else: z = z + 1
print(f"{x}.{y}.{z}")
PY
}
_devhooks_set_fe_version() {  # $1=new version (regex replace, preserves formatting)
  python3 - "${SCRIPT_DIR}/dashboard/frontend/package.json" "$1" <<'PY'
import re, sys
p, new = sys.argv[1], sys.argv[2]
s = open(p).read()
open(p, "w").write(re.sub(r'("version"\s*:\s*")[^"]*(")', r'\g<1>' + new + r'\g<2>', s, count=1))
PY
}

_devhooks_install() {
  git -C "$SCRIPT_DIR" config core.hooksPath .githooks
  chmod +x "$SCRIPT_DIR"/.githooks/* 2>/dev/null || true
  echo "Dev git hooks enabled (core.hooksPath=.githooks)."
  if command -v gitleaks &>/dev/null; then
    echo "  gitleaks: found — pre-commit blocks commits containing secrets."
  else
    echo "  gitleaks: NOT found — local leak scan skipped (CI still scans). Install: https://github.com/gitleaks/gitleaks"
  fi
  echo "  commit-msg: blocks subjects that are not Conventional Commits (see contributing.md)."
  echo "  pre-push: advisory reminders (frontend tag, WIP). Tag with: testbed dev-hooks release"
}
_devhooks_uninstall() {
  git -C "$SCRIPT_DIR" config --unset core.hooksPath 2>/dev/null || true
  echo "Dev git hooks disabled."
}
_devhooks_status() {
  local hp pkg last_tag last_ver
  hp="$(git -C "$SCRIPT_DIR" config --get core.hooksPath 2>/dev/null || true)"
  [ "$hp" = ".githooks" ] && echo "Dev hooks: enabled" || echo "Dev hooks: disabled (enable with: testbed dev-hooks on)"
  command -v gitleaks &>/dev/null && echo "gitleaks: installed" || echo "gitleaks: not installed (local leak scan skipped; CI scans)"
  echo "commit-msg: Conventional Commits validation active when hooks enabled"
  pkg="$(_devhooks_fe_version || true)"; last_tag="$(_devhooks_fe_last_tag || true)"; last_ver="${last_tag#dashboard-frontend-v}"
  echo "frontend: package.json v${pkg:-?}, last published ${last_tag:-<none>}"
  if [ -n "$pkg" ] && { [ -z "$last_tag" ] || [ "$pkg" != "$last_ver" ] || _devhooks_fe_changed_since "$last_tag"; }; then
    echo "  -> unpublished frontend changes; run: testbed dev-hooks release"
  else
    echo "  -> up to date"
  fi
}
# Advisory check used by the pre-push hook. Never blocks (returns 0).
_devhooks_check() {
  local branch pkg last_tag last_ver wip
  branch="$(git -C "$SCRIPT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  pkg="$(_devhooks_fe_version || true)"; last_tag="$(_devhooks_fe_last_tag || true)"; last_ver="${last_tag#dashboard-frontend-v}"
  if [ "$branch" = "main" ] && [ -n "$pkg" ]; then
    if [ -z "$last_tag" ]; then
      echo "⚠ frontend never published. Tag it with:  testbed dev-hooks release   (-> dashboard-frontend-v$pkg)" >&2
    elif [ "$pkg" != "$last_ver" ]; then
      echo "⚠ frontend v$pkg not tagged (last published v$last_ver). Publish with:  testbed dev-hooks release" >&2
    elif _devhooks_fe_changed_since "$last_tag"; then
      echo "⚠ frontend changed since v$last_ver, version not bumped. Publish with:  testbed dev-hooks release" >&2
    fi
  fi
  wip="$(git -C "$SCRIPT_DIR" log --format=%s '@{u}..HEAD' 2>/dev/null | grep -ciE '^(wip|fixup!|squash!)' || true)"
  [ "${wip:-0}" -gt 0 ] && echo "⚠ pushing ${wip} WIP/fixup commit(s) — consider squashing first." >&2
  return 0
}
_devhooks_release() {
  local area="${1:-frontend}" pkg last_tag last_ver bump newver
  if [ "$area" != "frontend" ]; then
    echo "Only 'frontend' is supported here. Docs (kelt-docs) publish automatically on push; NF/northbound images live in separate repos."
    return 1
  fi
  pkg="$(_devhooks_fe_version || true)"; last_tag="$(_devhooks_fe_last_tag || true)"; last_ver="${last_tag#dashboard-frontend-v}"
  [ -n "$pkg" ] || { echo "Cannot read dashboard/frontend/package.json version."; return 1; }

  if [ -n "$last_tag" ] && [ "$pkg" = "$last_ver" ]; then
    echo "frontend is at v$pkg (= last published). Pick a bump:" >&2
    bump="$(gum_choose_or_cancel "patch" "minor" "major")"
    [ -z "$bump" ] && { echo "Cancelled."; return 0; }
    newver="$(_devhooks_bump "$pkg" "$bump")"
    echo "Plan: bump package.json $pkg -> $newver, commit, tag dashboard-frontend-v$newver."
    gum_confirm "Proceed?" || { echo "Cancelled."; return 0; }
    _devhooks_set_fe_version "$newver"
    git -C "$SCRIPT_DIR" add dashboard/frontend/package.json
    git -C "$SCRIPT_DIR" commit -m "chore(frontend): release v$newver"
    git -C "$SCRIPT_DIR" tag "dashboard-frontend-v$newver"
  else
    newver="$pkg"
    echo "frontend package.json is v$pkg, not yet tagged. Plan: tag dashboard-frontend-v$pkg on HEAD."
    gum_confirm "Proceed?" || { echo "Cancelled."; return 0; }
    git -C "$SCRIPT_DIR" tag "dashboard-frontend-v$newver"
  fi

  if gum_confirm "Push commit (if any) + tag dashboard-frontend-v$newver now?"; then
    git -C "$SCRIPT_DIR" push
    git -C "$SCRIPT_DIR" push origin "dashboard-frontend-v$newver"
    echo "Pushed. CI builds ghcr.io/jacobbista/dashboard-frontend:$newver and :latest."
  else
    echo "Tag created locally. Push when ready:  git push && git push origin dashboard-frontend-v$newver"
  fi
}

do_dev_hooks() {
  case "${1:-status}" in
    on|install)   _devhooks_install ;;
    off|uninstall) _devhooks_uninstall ;;
    status)       _devhooks_status ;;
    check)        _devhooks_check "${2:-}" ;;
    release)      _devhooks_release "${2:-frontend}" ;;
    *) echo "Usage: $0 dev-hooks {on|off|status|release [frontend]}"; return 1 ;;
  esac
}

print_help() {
  cat <<EOF
NAME
    testbed-config - configure and drive the 5G K3s KubeEdge testbed

SYNOPSIS
    testbed-config [command] [args...]

DESCRIPTION
    Interactive TUI when called without arguments. All commands are also
    available non-interactively for scripts and CI. State is persisted to
    .testbed.env (config) and .testbed.secrets (secrets) in the repo root.

SETUP
    onboarding                   First-run wizard: check host requirements
                                 (vagrant, VirtualBox, vboxusers group,
                                 CPU virt, gum), offer auto-fixes, install
                                 alias, initialize config. Runs once
                                 automatically on the very first invocation.
    install                      Install 'testbed' alias + bash completion
                                 in ~/.bashrc (offers to apt-install gum).

DEPLOY
    up                           vagrant up with current config
    provision                    Full ansible provision (vagrant provision ansible)
    run-phase [phase-dir]        Run one ansible phase playbook standalone
    autostart [on|off|status]    Toggle systemd unit that runs 'vagrant up' on
                                 boot (system-wide, requires sudo).

CONFIGURE
    set-profile <laptop|server>  Resource profile
    edge <on|off>                Toggle edge VM
    ran <nic|disable>            Physical RAN bridge
    northbound <on|off>          Toggle the positioning/CAMARA feature (phases
                                 10-12 + placement-editor) in one command

EXTERNAL ACCESS
    auth-network [subcmd]        Subcmds:
                                   status, dev, auth, origin,
                                   positioning-origin, prefix, keycloak-url,
                                   preset-cloudflare <root-domain>
    dashboard-dev [true|false]   Toggle opt-in Vite dev frontend
    dashboard-auth [enabled|disabled]

IAM (Keycloak)
    iam reconcile {on|off|ask|status}
                                 Realm reconcile gate for phase 08. 'ask'
                                 (default) prompts on every phase 08 launch
                                 from the TUI. 'on'/'off' persist the answer.
                                 See docs/security/iam.md.

SECRETS
    iam-admin-password [pwd|--clear]
    secrets [generate-missing|manual|rotate|status|clear]

STATUS & TEST
    show                         Print current configuration
    endpoints                    Print service URLs (dashboard, demo, CAMARA,
                                 Keycloak) — external if set, else LAN NodePort
    env                          Print 'export' lines for shell eval
    tests [suite...]             Run test suites (interactive picker if none)

DEVELOPER
    dev-hooks {on|off|status}    Opt-in local git hooks (developer-only):
                                 pre-commit secret scan (gitleaks), commit-msg
                                 Conventional Commits check, pre-push advisory
                                 reminders. See docs/development/contributing.md.
    dev-hooks release [frontend] Tag + publish a new frontend version (confirmed).

HELP
    help, -h, --help             Show this page

EXAMPLES
    testbed install                          # first-run setup
    testbed up
    testbed auth-network preset-cloudflare mydomain.com
    testbed run-phase 09-dashboard
    testbed secrets rotate

FILES
    .testbed.env       persisted config (committed-safe)
    .testbed.secrets   passwords + client secrets (gitignored)
EOF
}

main() {
  load_config

  case "${1:-}" in
    show)
      show_status ;;
    set-profile)
      do_set_profile "${2:-}" ;;
    edge)
      do_edge "${2:-}" ;;
    ran)
      do_ran "${2:-}" ;;
    northbound)
      do_set_northbound "${2:-}" ;;
    dev-hooks)
      shift
      do_dev_hooks "$@" ;;
    iam-admin-password)
      do_iam_admin_password "${2:-}" ;;
    iam)
      shift
      do_iam "$@" ;;
    secrets)
      do_secrets "${2:-}" ;;
    auth-network)
      do_auth_network "${2:-}" "${3:-}" ;;
    dashboard-dev)
      do_set_dashboard_dev_enabled "${2:-}" ;;
    dashboard-auth)
      do_set_dashboard_auth "${2:-}" ;;
    run-phase)
      do_run_phase "${2:-}" ;;
    tests)
      shift
      do_tests "$@" ;;
    up)
      do_up ;;
    provision)
      do_provision ;;
    env)
      # Print export commands for shell eval
      echo "export TESTBED_PROFILE=${TESTBED_PROFILE}"
      echo "export EDGE_ENABLED=${EDGE_ENABLED}"
      echo "export DEPLOY_MODE=${DEPLOY_MODE}"
      echo "export PHYSICAL_RAN_ENABLED=${PHYSICAL_RAN_ENABLED}"
      echo "export PHYSICAL_RAN_BRIDGE=${PHYSICAL_RAN_BRIDGE}"
      echo "export NORTHBOUND_ENABLED=${NORTHBOUND_ENABLED}"
      echo "export DASHBOARD_DEV_ENABLED=${DASHBOARD_DEV_ENABLED}"
      echo "export DASHBOARD_AUTH_ENABLED=${DASHBOARD_AUTH_ENABLED}"
      echo "export EXTERNAL_BASE_DOMAIN=${EXTERNAL_BASE_DOMAIN}"
      echo "export KEYCLOAK_PATH_PREFIX=${KEYCLOAK_PATH_PREFIX}"
      echo "export DASHBOARD_KEYCLOAK_EXTERNAL_URL=${DASHBOARD_KEYCLOAK_EXTERNAL_URL}"
      echo "export DASHBOARD_KEYCLOAK_PATH_PREFIX=${DASHBOARD_KEYCLOAK_PATH_PREFIX}"
      echo "export DASHBOARD_EXTERNAL_ORIGIN=${DASHBOARD_EXTERNAL_ORIGIN}"
      echo "export DASHBOARD_DEV_EXTERNAL_URL=${DASHBOARD_DEV_EXTERNAL_URL}"
      echo "export CAMARA_GATEWAY_EXTERNAL_ORIGIN=${CAMARA_GATEWAY_EXTERNAL_ORIGIN}"
      echo "export POSITIONING_DEMO_EXTERNAL_ORIGIN=${POSITIONING_DEMO_EXTERNAL_ORIGIN}"
      echo "export KEYCLOAK_REALM_RECONCILE=${KEYCLOAK_REALM_RECONCILE}"
      echo "# Secrets are stored in .testbed.secrets:"
      echo "#   KEYCLOAK_ADMIN_PASSWORD"
      echo "#   CAMARA_CLIENT_SECRET"
      echo "#   DASHBOARD_READONLY_SECRET"
      ;;
    install)
      do_install_cli ;;
    endpoints)
      do_endpoints ;;
    onboarding)
      do_onboarding ;;
    autostart)
      do_autostart "${2:-}" ;;
    help|--help|-h)
      print_help ;;
    "")
      if ! is_onboarded; then
        do_onboarding
        echo ""
      fi
      check_gum
      interactive_menu ;;
    *)
      echo "Unknown command: $1 (try: $0 help)"
      exit 1 ;;
  esac
}

