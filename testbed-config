# ─── IAM realm reconcile gate ──────────────────────────────────────────
# Keycloak imports the realm JSON only on first boot. Phase 08 includes a
# reconcile step that PUTs redirect URIs, web origins, post-logout URIs,
# roles, groups, and composites via the Keycloak admin API so changes to
# the realm template propagate without resetting the database.
#
# The gate has three states stored in .testbed.env:
#   ask   -> prompt the operator on every phase 08 launch (default)
#   true  -> reconcile without prompting
#   false -> skip reconcile without prompting
#
# Prompting only happens in interactive (TTY) launches of phase 08 via
# do_run_phase. Non-interactive callers (CI, scripted) honor the stored
# value or the KEYCLOAK_REALM_RECONCILE environment variable directly.
do_iam_reconcile() {
  local value="${1:-}"
  case "$value" in
    "")
      echo "Usage: testbed iam reconcile {on|off|ask|status}"
      return 1
      ;;
    status)
      echo "IAM realm reconcile: ${KEYCLOAK_REALM_RECONCILE}"
      return 0
      ;;
    on|true|always)
      KEYCLOAK_REALM_RECONCILE="true"
      ;;
    off|false|never)
      KEYCLOAK_REALM_RECONCILE="false"
      ;;
    ask|prompt)
      KEYCLOAK_REALM_RECONCILE="ask"
      ;;
    *)
      echo "Unknown value: $value (try on|off|ask|status)"
      return 1
      ;;
  esac
  save_config
  echo "IAM realm reconcile default: ${KEYCLOAK_REALM_RECONCILE}"
}

do_iam() {
  local action="${1:-}"
  if [[ -z "$action" ]] && $HAS_GUM; then
    action="$(gum_choose_or_cancel "reconcile status" "reconcile on" "reconcile off" "reconcile ask")"
    [[ -z "$action" ]] && { echo "Cancelled."; return 0; }
    case "$action" in
      "reconcile status") do_iam_reconcile status ;;
      "reconcile on")     do_iam_reconcile on ;;
      "reconcile off")    do_iam_reconcile off ;;
      "reconcile ask")    do_iam_reconcile ask ;;
    esac
    return $?
  fi
  case "$action" in
    reconcile) do_iam_reconcile "${2:-}" ;;
    *)
      echo "Usage: testbed iam reconcile {on|off|ask|status}"
      return 1
      ;;
  esac
}

# Interactive prompt invoked before phase 08 runs. Sets the global
# KC_RECONCILE_THIS_RUN to "true" or "false". The function writes all
# UI to stderr so the caller can keep stdout clean for downstream
# captures (do_run_phase used to inline this via $(...), which detached
# gum from the tty and folded ANSI bytes into the command line).
prompt_kc_reconcile() {
  KC_RECONCILE_THIS_RUN=""

  if ! $HAS_GUM || [[ ! -t 0 ]]; then
    case "${KEYCLOAK_REALM_RECONCILE}" in
      true)  KC_RECONCILE_THIS_RUN="true";  return 0 ;;
      false) KC_RECONCILE_THIS_RUN="false"; return 0 ;;
      # 'ask' with no operator (CI, non-interactive) defaults to false.
      *)     KC_RECONCILE_THIS_RUN="false"; return 0 ;;
    esac
  fi

  case "${KEYCLOAK_REALM_RECONCILE}" in
    true|false)
      KC_RECONCILE_THIS_RUN="${KEYCLOAK_REALM_RECONCILE}"
      return 0
      ;;
  esac

  # 'ask' branch: explain and prompt. All output redirected to stderr.
  gum style --foreground 12 --bold "Keycloak realm reconcile" >&2
  cat <<'EXPL' >&2

Keycloak keeps the realm it imported on first boot, so later template
edits (dashboard redirect URIs, web origins, roles, groups, composites)
do NOT reach a running cluster on their own. Reconcile pushes them via
the admin API. It does not touch users, passwords, or sessions.

Apply it after changing the external origin or base domain, or any realm
template edit. Skip it only if you hand-edited the dashboard client in the
Keycloak console and want to keep that.

EXPL

  local choice
  choice="$(gum_choose_or_cancel \
    "Apply now: push template to Keycloak (this run)" \
    "Skip: leave the running realm unchanged (this run)" \
    "Apply now, and always (save as default)" \
    "Skip, and never (save as default)")"
  case "$choice" in
    "Apply now: push template to Keycloak (this run)")
      KC_RECONCILE_THIS_RUN="true"
      ;;
    "Skip: leave the running realm unchanged (this run)")
      KC_RECONCILE_THIS_RUN="false"
      ;;
    "Apply now, and always (save as default)")
      KEYCLOAK_REALM_RECONCILE="true"
      save_config >&2
      KC_RECONCILE_THIS_RUN="true"
      ;;
    "Skip, and never (save as default)")
      KEYCLOAK_REALM_RECONCILE="false"
      save_config >&2
      KC_RECONCILE_THIS_RUN="false"
      ;;
    *)
      KC_RECONCILE_THIS_RUN="false"
      ;;
  esac
}

